{
  "name": "@dltkrichardhuska/harmony-design-system",
  "version": "0.9.0",
  "description": "Harmony Design System - Internal UI components, layouts, and design tokens for Deltek Astro applications",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DLTKRichardHuska/harmonycomponentspublic-figma-test.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "keywords": [
    "astro",
    "design-system",
    "ui-components",
    "deltek",
    "internal"
  ],
  "files": [
    "src/components/ui",
    "src/data",
    "src/layouts",
    "src/styles",
    "src/tokens",
    "public",
    "docs/customization",
    "docs/RULES.md",
    "scripts/copy-harmony-component.cjs",
    "scripts/check-harmony-updates.cjs",
    "scripts/diff-harmony-component.cjs",
    "examples",
    "CHANGELOG.md",
    "README.md"
  ],
  "exports": {
    "./ui": "./src/components/ui/index.ts",
    "./ui/*": "./src/components/ui/*.astro",
    "./layouts/*": "./src/layouts/*.astro",
    "./styles/*.css": "./src/styles/*.css",
    "./tokens": "./src/tokens/index.ts",
    "./tokens/*.json": "./src/tokens/*.json",
    "./public/*": "./public/*",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@tabler/icons": "^3.0.0",
    "astro": "^7.0.0",
    "heroicons": "^2.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "astro dev",
    "start": "serve dist -l ${PORT:-3000}",
    "build": "astro build && node scripts/extract-usage-rules.js",
    "check": "astro check --tsconfig tsconfig.astro-check.json",
    "generate:rules": "node scripts/extract-usage-rules.js",
    "preview": "astro preview",
    "astro": "astro",
    "changelog": "node scripts/changelog/run-automation.js",
    "changelog:migrate-baseline": "node scripts/changelog/migrate-version-baseline.js",
    "changelog:snapshot": "node scripts/changelog/generate-snapshot.js",
    "release:promote": "node scripts/changelog/promote-release.js",
    "generate:inventory": "node scripts/generate-component-props-inventory.js --write",
    "validate:catalog": "node scripts/validate-component-catalog.js",
    "validate:tokens": "node scripts/validate-tokens.mjs",
    "docs:check": "npm run validate:catalog && npm run validate:tokens && npm run generate:inventory && node scripts/compare-docs-with-components.js",
    "harmony:copy": "node scripts/copy-harmony-component.cjs",
    "harmony:check-updates": "node scripts/check-harmony-updates.cjs",
    "harmony:diff": "node scripts/diff-harmony-component.cjs",
    "inline:icon-manifest": "node scripts/inline-icon-manifest.js"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.19",
    "@tabler/icons": "^3.45.0",
    "@types/node": "^26.1.1",
    "astro": "^7.1.3",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "deep-diff": "^1.0.2",
    "fuse.js": "^7.5.0",
    "heroicons": "^2.2.0",
    "husky": "^9.1.7",
    "playwright": "^1.61.1",
    "postcss": "^8.5.22",
    "postcss-value-parser": "^4.2.0",
    "serve": "^14.2.6",
    "simple-git": "^3.36.0",
    "typescript": "^6.0.3"
  }
}
