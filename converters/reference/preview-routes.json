{
  "version": 1,
  "description": "Astro reference preview routes for automated conversion verification capture.",
  "dev": {
    "command": "npm run dev",
    "cwd": ".",
    "port": 4321,
    "baseUrl": "http://localhost:4321"
  },
  "scopes": {
