{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harmony.deltek.com/schemas/defect-report.json",
  "title": "Conversion Defect Report",
  "type": "object",
  "required": ["target", "scope", "iteration", "artifactType", "generatedAt", "summary", "result"],
  "properties": {
    "target": { "type": "string" },
    "scope": { "type": "string" },
    "iteration": { "type": "integer", "minimum": 1 },
    "artifactType": {
      "type": "string",
      "enum": ["html", "image", "json", "other"]
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "referenceVersion": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["open", "fixed", "blocked", "deferred", "total"],
      "properties": {
        "open": { "type": "integer", "minimum": 0 },
        "fixed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "deferred": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "result": { "type": "string", "enum": ["PASS", "FAIL"] },
    "artifacts": {
      "type": "object",
      "properties": {
        "reference": { "type": "string" },
        "converted": { "type": "string" }
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "category", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^DEF-[0-9]{3}$" },
          "status": {
            "type": "string",
            "enum": ["open", "fixed", "blocked", "deferred"]
          },
          "category": {
            "type": "string",
            "enum": ["structure", "visual", "a11y", "tokens", "behavior", "mapping", "api", "other"]
          },
          "reference": { "type": "string" },
          "converted": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" },
          "remediationHint": { "type": "string" },
          "blockedReason": { "type": "string" }
        }
      }
    }
  }
}
