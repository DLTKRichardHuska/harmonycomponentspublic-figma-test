{
  "name": "@dltkrichardhuska/harmony-design-system-react-mui",
  "version": "0.9.0",
  "description": "Harmony Design System — React + MUI conversion",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DLTKRichardHuska/harmonycomponentspublic-figma-test.git",
    "directory": "conversions/harmony-design-system-react-mui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "files": [
    "dist",
    "src/components",
    "src/fonts.ts",
    "src/layouts",
    "src/styles"
  ],
  "exports": {
    "./theme": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts"
    },
    "./fonts": "./src/fonts.ts",
    "./styles/*": "./src/styles/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib",
    "build:lib": "tsup",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/material": "^9.2.0",
    "@mui/x-date-pickers": "^9.9.0",
    "dayjs": "^1.11.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@fontsource/figtree": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/lexend": "^5.2.11",
    "@heroicons/react": "^2.2.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-date-pickers": "^9.9.0",
    "@tabler/icons-react": "^3.44.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
