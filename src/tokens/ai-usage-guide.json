  "figmaMapping": {
    "generalRules": {
      "description": "When converting Figma designs to Harmony components, follow these mapping rules",
      "process": [
        "1. Identify the component type in Figma",
        "2. Find the matching Harmony component",
        "3. Map variants and props based on Figma properties",
        "4. Apply appropriate spacing using design tokens",
        "5. Ensure theme compatibility (light/dark mode)"
      ]
    },
    "commonMappings": {
      "buttons": {
        "figma": "Button components, CTAs, icon buttons",
        "harmony": "Button component",
        "variantMapping": {
          "Primary/CTA": "variant='primary'",
          "Secondary": "variant='secondary'",
          "Tertiary": "variant='tertiary'",
          "Outline": "variant='outline'",
          "Ghost/Text": "variant='ghost'",
          "Destructive/Danger": "variant='destructive'"
        }
      },
      "cards": {
        "figma": "Card components, containers, elevated surfaces",
        "harmony": "Card component",
        "props": {
          "With shadow": "elevated={true}",
          "Clickable": "interactive={true}",
          "Primary color": "primary={true}"
        }
      },
      "forms": {
        "figma": "Input fields, text areas, selects",
        "harmony": "Input, Textarea, Dropdown components",
        "mapping": {
          "Text input": "Input type='text'",
          "Email input": "Input type='email'",
          "Password input": "Input type='password'",
          "Textarea": "Textarea",
          "Select/Dropdown": "Dropdown",
          "Number input": "NumberInput",
          "Date picker": "DateInput type='date'",
          "Time picker": "DateInput type='time'"
        }
      },
      "navigation": {
        "figma": "Navigation bars, sidebars, menus",
        "harmony": "ShellLayout with appropriate sidebars",
        "mapping": {
          "Top nav bar": "ShellHeader (in ShellLayout)",
          "Left sidebar": "LeftSidebar (in ShellLayout)",
          "Right sidebar": "RightSidebar (in ShellLayout)",
          "Bottom tabs": "ShellFooter (in ShellLayout)",
          "Floating toolbar": "FloatingNav (in ShellLayout, CP theme)"
        }
      },
      "feedback": {
        "figma": "Alerts, badges, tooltips, spinners",
        "harmony": "Alert, Badge, Tooltip, Spinner components",
        "mapping": {
          "Alert/Notification": "Alert with appropriate variant",
          "Status badge": "Badge with appropriate variant",
          "Tooltip": "Tooltip",
          "Loading spinner": "Spinner"
        }
      },
      "dataDisplay": {
        "figma": "Tables, lists, kanban boards",
        "harmony": "Table, ListMenu, Kanban components",
        "mapping": {
          "Data table": "Table",
          "List menu": "ListMenu",
          "Kanban board": "Kanban"
        }
      }
    }
  },

