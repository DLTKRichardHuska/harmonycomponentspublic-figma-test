{
  "$schema": "https://harmony-ds.com/tokens/ai-usage-guide.schema.json",
  "name": "Harmony Design System AI Usage Guide",
  "version": "1.0.0",
  "description": "Comprehensive usage guidelines for AI to properly use the Harmony Design System",
  "generatedAt": "2026-01-15T00:00:00.000Z",
  
  "setup": {
    "importStyles": {
      "description": "Always import the global CSS file first to get all design tokens and component styles",
      "example": "import './src/styles/global.css';",
      "order": "Must be imported before any component usage"
    },
    "importComponents": {
      "description": "Import components from the ui directory",
      "example": "import { Button, Card, Dialog } from './src/components/ui';",
      "note": "Components are Astro components, so use them in .astro files or Astro-compatible frameworks"
    },
    "requiredFiles": [
      "src/styles/global.css",
      "src/components/ui/*.astro",
      "src/tokens/*.json",
      "public/* (for icons and assets)"
    ],
    "sparseCheckout": {
      "description": "Paths to include when cloning only components (excluding documentation site)",
      "paths": [
        "src/components",
        "src/styles",
        "src/tokens",
        "public",
        "README.md",
        "package.json"
      ],
      "gitCommand": "git sparse-checkout set src/components src/styles src/tokens public README.md package.json",
      "excludedPaths": [
        "src/pages",
        "src/layouts/DocsLayout.astro",
        "src/components/ComponentDoc.astro",
        "src/data",
        "astro.config.mjs",
        "scripts"
      ],
      "note": "These paths ensure all components, styles, tokens, and assets are included while excluding the documentation site"
    }
  },

  "theming": {
    "applyTheme": {
      "description": "Apply a product theme by adding class to html element",
      "method": "document.documentElement.classList.add('theme-{name}')",
      "themes": ["cp", "vp", "ppm", "maconomy"],
      "example": "document.documentElement.classList.add('theme-cp');"
    },
    "toggleDarkMode": {
      "description": "Toggle between light and dark mode",
      "method": "document.documentElement.classList.toggle('dark')",
      "default": "Dark mode is default. Remove 'dark' class for light mode.",
      "example": "document.documentElement.classList.toggle('dark');"
    },
    "themeDetection": {
      "description": "ShellLayout automatically detects theme from html class and adjusts layout",
      "behavior": "When ShellLayout has data-use-theme-detection='true', it watches for theme class changes and updates sidebar variants, footer visibility, and floating nav visibility automatically",
      "note": "Theme detection is enabled by default unless explicitly disabled via props"
    },
    "themeSpecificBehavior": {
      "cp": {
        "hasFloatingNav": true,
        "hasFooter": false,
        "leftSidebarVariant": "cp",
        "rightSidebarVariant": "cp"
      },
      "vp": {
        "hasFloatingNav": false,
        "hasFooter": true,
        "leftSidebarVariant": "vp",
        "rightSidebarVariant": "vp"
      },
      "ppm": {
        "hasFloatingNav": false,
        "hasFooter": true,
        "leftSidebarVariant": "ppm",
        "rightSidebarVariant": "ppm"
      },
      "maconomy": {
        "hasFloatingNav": false,
        "hasFooter": true,
        "leftSidebarVariant": "maconomy",
        "rightSidebarVariant": "maconomy"
      }
    }
  },

  "shellLayout": {
    "description": "Complete application shell template with header, sidebars, footer, and content area",
    "components": {
      "ShellLayout": {
        "description": "Main wrapper component that provides the complete application structure",
        "filePath": "src/layouts/ShellLayout.astro",
        "usage": "Wrap your entire application content with ShellLayout",
        "props": {
          "productName": "Product name displayed in header",
          "logoSrc": "Path to logo image",
          "companyName": "Company name for company picker",
          "showCompanyPicker": "Show/hide company picker dropdown",
          "companyColor": "Color for company indicator",
          "showFloatingNav": "Show CP-specific floating nav (auto-detected if not set)",
          "floatingNavVariant": "'full' | 'compact'",
          "tabs": "Array of Tab objects for footer (VP/PPM/Maconomy)",
          "leftSidebarVariant": "'cp' | 'vp' | 'ppm' | 'maconomy' (auto-detected if not set)",
          "rightSidebarVariant": "'cp' | 'vp' | 'ppm' | 'maconomy' (auto-detected if not set)",
          "pageHeaderTitle": "Title for page header",
          "pageHeaderSubtitle": "Subtitle for page header",
          "pageHeaderPrimaryButton": "Primary action button config",
          "pageHeaderOutlineButton1-3": "Up to 3 outline action buttons",
          "leftPanel": "Left slide-out panel config",
          "rightPanel": "Right slide-out panel config"
        }
      },
      "ShellHeader": {
        "description": "Top navigation bar with branding and user controls",
        "filePath": "src/components/ui/ShellHeader.astro",
        "usage": "Automatically included in ShellLayout, but can be used standalone"
      },
      "ShellFooter": {
        "description": "Bottom tab bar for workspace navigation (VP, PPM, Maconomy themes)",
        "filePath": "src/components/ui/ShellFooter.astro",
        "usage": "Automatically shown/hidden by ShellLayout based on theme",
        "note": "CP theme uses FloatingNav instead of Footer"
      },
      "FloatingNav": {
        "description": "CP-specific floating navigation toolbar below header",
        "filePath": "src/components/ui/FloatingNav.astro",
        "usage": "Automatically shown/hidden by ShellLayout based on theme",
        "note": "Only shown for CP theme"
      },
      "LeftSidebar": {
        "description": "Primary navigation sidebar (supports all 4 themes)",
        "filePath": "src/components/ui/LeftSidebar.astro",
        "usage": "Automatically included in ShellLayout with theme-specific styling",
        "variants": ["cp", "vp", "ppm", "maconomy"]
      },
      "RightSidebar": {
        "description": "Secondary actions sidebar (supports all 4 themes)",
        "filePath": "src/components/ui/RightSidebar.astro",
        "usage": "Automatically included in ShellLayout with theme-specific styling",
        "variants": ["cp", "vp", "ppm", "maconomy"]
      },
      "ShellPageHeader": {
        "description": "Page title and action buttons area",
        "filePath": "src/components/ui/ShellPageHeader.astro",
        "usage": "Pass pageHeaderTitle prop to ShellLayout to show page header",
        "note": "Appears above main content area"
      },
      "ShellPanel": {
        "description": "Slide-out contextual panel from left or right sidebar",
        "filePath": "src/components/ui/ShellPanel.astro",
        "usage": "Pass leftPanel or rightPanel prop to ShellLayout",
        "props": {
          "side": "'left' | 'right'",
          "open": "boolean - controls panel visibility",
          "title": "Panel header title",
          "titleIcon": "Optional icon name",
          "headerVariant": "'theme' | 'default'",
          "width": "'narrow' | 'full'",
          "showClose": "Show close button",
          "showPopout": "Show popout/detach button"
        }
      }
    },
    "spacingRules": {
      "critical": "ALWAYS use these CSS variables for padding when content is inside ShellLayout main area. Never use fixed pixel values.",
      "mainContentPadding": {
        "withFloatingNav": {
          "description": "When FloatingNav is visible (CP theme)",
          "top": "var(--shell-layout-padding-top)",
          "topValue": "88px",
          "sides": "calc(var(--shell-layout-padding-side-default) + var(--space-5))",
          "sidesValue": "52px + 20px = 72px",
          "bottom": "var(--space-6)",
          "bottomValue": "24px",
          "cssExample": "padding: var(--shell-layout-padding-top) calc(var(--shell-layout-padding-side-default) + var(--space-5)) var(--space-6) calc(var(--shell-layout-padding-side-default) + var(--space-5));"
        },
        "withoutFloatingNav": {
          "description": "When FloatingNav is not visible (VP, PPM, Maconomy themes)",
          "top": "var(--space-5)",
          "topValue": "20px",
          "sides": "calc(var(--shell-layout-padding-side-default) + var(--space-5))",
          "sidesValue": "52px + 20px = 72px",
          "bottom": "var(--space-6)",
          "bottomValue": "24px",
          "cssExample": "padding-top: var(--space-5); padding-right: calc(var(--shell-layout-padding-side-default) + var(--space-5)); padding-bottom: var(--space-6); padding-left: calc(var(--shell-layout-padding-side-default) + var(--space-5));"
        },
        "responsive": {
          "tablet": {
            "description": "Tablet breakpoint (max-width: 1024px)",
            "sides": "calc(var(--shell-layout-padding-side-tablet) + var(--space-5))",
            "sidesValue": "32px + 20px = 52px"
          },
          "mobile": {
            "description": "Mobile breakpoint (max-width: 768px)",
            "sides": "var(--shell-layout-padding-side-mobile)",
            "sidesValue": "16px",
            "note": "Sidebars are hidden on mobile, so padding is reduced"
          }
        },
        "rule": "The ShellLayout component automatically applies these paddings to .shell-layout__main. Your content inside the main slot should NOT add additional padding unless creating internal spacing between elements."
      },
      "spacingTokens": {
        "--shell-layout-padding-top": "88px (for floating nav)",
        "--shell-layout-padding-side-default": "52px (sidebar width)",
        "--shell-layout-padding-side-tablet": "32px",
        "--shell-layout-padding-side-mobile": "16px",
        "--space-5": "20px",
        "--space-6": "24px"
      }
    },
    "usageExample": {
      "description": "Basic ShellLayout usage",
      "code": "<ShellLayout\n  productName=\"My App\"\n  logoSrc=\"/logos/CPVPLogo.svg\"\n  companyName=\"Acme Corp\"\n  pageHeaderTitle=\"Dashboard\"\n  pageHeaderSubtitle=\"Overview of your data\"\n>\n  <!-- Your content here - padding is automatically applied -->\n  <Card>\n    <div class=\"card__body\">\n      Content goes here\n    </div>\n  </Card>\n</ShellLayout>"
    }
  },

