    "spacing": {
      "rule": "Always use design tokens (--space-*) for spacing, never fixed pixel values",
      "commonTokens": {
        "--space-1": "4px",
        "--space-2": "8px",
        "--space-3": "12px",
        "--space-4": "16px",
        "--space-5": "20px",
        "--space-6": "24px",
        "--space-8": "32px",
        "--space-12": "48px"
      }
    },
    "colors": {
      "rule": "Always use semantic color tokens, never hardcoded colors",
      "commonTokens": {
        "--text-primary": "Primary text color",
        "--text-secondary": "Secondary text color",
        "--text-muted": "Muted text color",
        "--theme-primary": "Theme primary color",
        "--border-color": "Border color",
        "--card-bg": "Card background",
        "--page-bg": "Page background"
      }
    },
    "theming": {
      "rule": "Always test components in both light and dark modes",
      "rule2": "Ensure components work with all 4 themes (cp, vp, ppm, maconomy)",
      "rule3": "Use theme-aware tokens that automatically adjust per theme"
    },
    "accessibility": {
      "rule": "All components include proper ARIA attributes",
      "rule2": "Ensure keyboard navigation works",
      "rule3": "Maintain proper color contrast ratios"
    },
    "shellLayout": {
      "criticalRule": "When using ShellLayout, NEVER add custom padding to content inside the main slot. The ShellLayout automatically applies correct spacing. Only add internal spacing between elements using design tokens.",
      "example": "Correct: <ShellLayout><Card><div class=\"card__body\">Content</div></Card></ShellLayout>",
      "incorrect": "Wrong: <ShellLayout><div style=\"padding: 20px\"><Card>Content</Card></div></ShellLayout>"
    }
  }
}
