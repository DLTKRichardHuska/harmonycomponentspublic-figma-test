---
import DocsLayout from '../layouts/DocsLayout.astro';
import Icon from '../components/ui/Icon.astro';
import Badge from '../components/ui/Badge.astro';
import Input from '../components/ui/Input.astro';
import Label from '../components/ui/Label.astro';

// Load changes history
interface Change {
  date?: string;
  type?: string;
  category?: string;
  changeType?: string;
  name?: string;
  description?: string;
  details?: any;
}

let changesHistory: { changes: Change[] } = { changes: [] };
try {
  const historyData: any = await import('../tokens/changes-history.json');
  changesHistory = historyData.default || { changes: [] };
} catch (e) {
  console.warn('Could not load changes history');
}

// Process changes
const changes: Change[] = changesHistory.changes || [];

// Group changes by date
const groupedByDate: Record<string, Change[]> = {};
changes.forEach((change: Change) => {
  if (!change.date) return;
  const date = new Date(change.date);
  const dateKey = date.toLocaleDateString('en-US', { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
  });
  
  if (!groupedByDate[dateKey]) {
    groupedByDate[dateKey] = [];
  }
  groupedByDate[dateKey].push(change);
});

// Sort dates (newest first)
const sortedDates = Object.keys(groupedByDate).sort((a, b) => {
  const dateA = new Date(a);
  const dateB = new Date(b);
  return dateB.getTime() - dateA.getTime();
});
---

<DocsLayout title="Updates" description="Track changes to components and design tokens in the Harmony Design System.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Updates & Changelog</h1>
        {changes.length > 0 && (
          <span class="badge badge--primary">{changes.length} change{changes.length > 1 ? 's' : ''}</span>
        )}
      </div>
      <p class="page-header__description">
        Stay up to date with the latest changes to components and design tokens. All changes are tracked automatically and displayed in plain English.
      </p>
      <div class="flex items-center gap-2 mt-4 text-sm text-muted">
        <Icon name="clock" size="xs" />
        <span>Last updated: <time id="last-updated-time" datetime={new Date().toISOString()}>{new Date().toLocaleString('en-US', { 
          month: 'short', 
          day: 'numeric', 
          hour: 'numeric', 
          minute: '2-digit' 
        })}</time></span>
        <span class="text-muted">•</span>
        <span>Updates every 5 minutes</span>
      </div>
    </header>

    <!-- Filters and Search -->
    <div class="card p-6 space-y-4">
      <div class="flex flex-wrap items-center gap-4">
        <div class="flex-1 min-w-[200px]">
          <Label for="search-input">Search</Label>
          <Input
            type="search"
            id="search-input"
            placeholder="Search changes..."
            icon="magnifying-glass"
            class="w-full"
          />
        </div>
        
        <div class="min-w-[150px]">
          <label for="type-filter" class="label">
            <span class="label__text">Type</span>
          </label>
          <select id="type-filter" class="input input--md w-full">
            <option value="all">All Types</option>
            <option value="component">Components</option>
            <option value="token">Tokens</option>
          </select>
        </div>
        
        <div class="min-w-[150px]">
          <label for="change-filter" class="label">
            <span class="label__text">Change</span>
          </label>
          <select id="change-filter" class="input input--md w-full">
            <option value="all">All Changes</option>
            <option value="added">Added</option>
            <option value="modified">Modified</option>
            <option value="removed">Removed</option>
          </select>
        </div>
      </div>
      
      <div id="filter-results" class="text-sm text-muted hidden">
        Showing <span id="filter-count">0</span> of {changes.length} changes
      </div>
    </div>

    <!-- Changes List -->
    {changes.length === 0 ? (
      <div class="card p-12 text-center">
        <Icon name="sparkles" size="lg" class="mx-auto mb-4 text-muted" />
        <h3 class="text-lg font-semibold mb-2">No changes yet</h3>
        <p class="text-muted">
          Changes will appear here once components or tokens are added, modified, or removed.
        </p>
      </div>
    ) : (
      <div id="changes-container" class="space-y-8">
        {sortedDates.map((dateKey) => {
          const dateChanges = groupedByDate[dateKey];
          return (
            <section class="space-y-4">
              <div class="flex items-center gap-3">
                <h2 class="section__title section__title--sm">{dateKey}</h2>
                <span class="badge badge--secondary">{dateChanges.length} change{dateChanges.length > 1 ? 's' : ''}</span>
              </div>
              
              <div class="space-y-3">
                {dateChanges.map((change) => {
                  const changeTypeVariant = 
                    change.changeType === 'added' ? 'success' :
                    change.changeType === 'removed' ? 'error' :
                    'warning';
                  
                  const changeTypeLabel = 
                    change.changeType === 'added' ? 'Added' :
                    change.changeType === 'removed' ? 'Removed' :
                    'Modified';
                  
                  const iconName = 
                    change.type === 'component' ? 'cube' :
                    change.category === 'colors' ? 'swatch' :
                    change.category === 'typography' ? 'document-text' :
                    change.category === 'spacing' ? 'arrows-pointing-out' :
                    change.category === 'elevations' ? 'squares-2x2' :
                    'clock';
                  
                  return (
                    <div 
                      class="change-item card p-5 hover:shadow-md transition-shadow"
                      data-type={change.type || ''}
                      data-change-type={change.changeType || ''}
                      data-name={(change.name || '').toLowerCase()}
                      data-description={(change.description || '').toLowerCase()}
                    >
                      <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 mt-1">
                          <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center">
                            <Icon name={iconName} size="sm" class="text-muted" />
                          </div>
                        </div>
                        
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-3 mb-2">
                            <h3 class="font-semibold text-base">{change.name || 'Unnamed'}</h3>
                            <Badge variant={changeTypeVariant as 'success' | 'error' | 'warning'}>
                              {changeTypeLabel}
                            </Badge>
                            {change.category && change.type === 'token' && (
                              <Badge variant="default">
                                {change.category}
                              </Badge>
                            )}
                          </div>
                          
                          <p class="text-sm text-muted leading-relaxed">
                            {change.description || 'No description available'}
                          </p>
                          
                          {change.date && (
                            <div class="mt-3 text-xs text-muted flex items-center gap-2">
                              <Icon name="clock" size="xs" />
                              <time datetime={change.date}>
                                {new Date(change.date).toLocaleTimeString('en-US', { 
                                  hour: 'numeric', 
                                  minute: '2-digit' 
                                })}
                              </time>
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>
    )}
  </article>

  <script>
    // Define Change interface for TypeScript
    interface Change {
      date?: string;
      type?: string;
      category?: string;
      changeType?: string;
      name?: string;
      description?: string;
      details?: any;
    }
    
    // Auto-refresh functionality - update content dynamically without page reload
    if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
      let lastChangesHash: string | null = null;
      let isUpdating = false;
      
      // Create a simple hash of changes for comparison
      function getChangesHash(changes: Change[]) {
        if (!changes || changes.length === 0) return 'empty';
        // Use length, first change date/name, and last change date/name for better detection
        const first = changes[0];
        const last = changes[changes.length - 1];
        return `${changes.length}-${first.date || ''}-${first.name || ''}-${last.date || ''}-${last.name || ''}`;
      }
      
      // Function to update the last updated timestamp
      function updateLastUpdatedTime() {
        const lastUpdatedElement = document.getElementById('last-updated-time');
        if (lastUpdatedElement) {
          const now = new Date();
          lastUpdatedElement.setAttribute('datetime', now.toISOString());
          lastUpdatedElement.textContent = now.toLocaleString('en-US', { 
            month: 'short', 
            day: 'numeric', 
            hour: 'numeric', 
            minute: '2-digit' 
          });
        }
      }
      
      // Set initial hash after a short delay to allow page to load
      setTimeout(async () => {
        try {
          const response = await fetch('/src/tokens/changes-history.json?' + Date.now());
          if (response.ok) {
            const data = await response.json();
            lastChangesHash = getChangesHash(data.changes);
            // Set initial timestamp
            updateLastUpdatedTime();
          }
        } catch (e) {
          // Ignore initial fetch errors
        }
      }, 1000);
      
      setInterval(async () => {
        if (isUpdating) return;
        
        try {
          // Fetch latest changes
          const response = await fetch('/src/tokens/changes-history.json?' + Date.now());
          if (!response.ok) return;
          
          const data = await response.json();
          const newHash = getChangesHash(data.changes);
          
          // Update timestamp on every check (even if no changes)
          updateLastUpdatedTime();
          
          // Only update if changes actually changed and we have a baseline
          if (lastChangesHash !== null && newHash !== lastChangesHash) {
            isUpdating = true;
            
            // Preserve scroll position
            const scrollY = window.scrollY;
            
            // Update the page content
            updateChangesContent(data.changes);
            
            // Restore scroll position after a brief delay
            setTimeout(() => {
              window.scrollTo(0, scrollY);
              isUpdating = false;
            }, 100);
          }
          
          if (lastChangesHash === null) {
            lastChangesHash = newHash;
          }
        } catch (error) {
          // Silently fail - don't interrupt user experience
          console.debug('Update check failed:', error);
        }
      }, 300000); // Check every 5 minutes (300000ms)
      
      // Function to update changes content dynamically
      function updateChangesContent(changes: Change[]) {
        const changesContainer = document.getElementById('changes-container');
        const pageHeader = document.querySelector('.page-header');
        
        if (!changesContainer) return;
        
        // Group changes by date (same logic as server-side)
        const groupedByDate: Record<string, Change[]> = {};
        changes.forEach((change) => {
          if (!change.date) return;
          const date = new Date(change.date);
          const dateKey = date.toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          });
          
          if (!groupedByDate[dateKey]) {
            groupedByDate[dateKey] = [];
          }
          groupedByDate[dateKey].push(change);
        });
        
        // Sort dates (newest first)
        const sortedDates = Object.keys(groupedByDate).sort((a, b) => {
          const dateA = new Date(a);
          const dateB = new Date(b);
          return dateB.getTime() - dateA.getTime();
        });
        
        // Update total count in header
        if (pageHeader) {
          const badge = pageHeader.querySelector('.badge');
          if (badge) {
            badge.textContent = `${changes.length} change${changes.length !== 1 ? 's' : ''}`;
          }
        }
        
        // Clear and rebuild container
        changesContainer.innerHTML = '';
        
        if (sortedDates.length === 0) {
          changesContainer.innerHTML = `
            <div class="card p-12 text-center">
              <h3 class="text-lg font-semibold mb-2">No changes yet</h3>
              <p class="text-muted">
                Changes will appear here once components or tokens are added, modified, or removed.
              </p>
            </div>
          `;
          return;
        }
        
        // Rebuild sections
        sortedDates.forEach((dateKey) => {
          const dateChanges = groupedByDate[dateKey];
          const section = document.createElement('section');
          section.className = 'space-y-4';
          
          const header = document.createElement('div');
          header.className = 'flex items-center gap-3';
          header.innerHTML = `
            <h2 class="section__title section__title--sm">${dateKey}</h2>
            <span class="badge badge--secondary">${dateChanges.length} change${dateChanges.length !== 1 ? 's' : ''}</span>
          `;
          section.appendChild(header);
          
          const itemsContainer = document.createElement('div');
          itemsContainer.className = 'space-y-3';
          
          dateChanges.forEach((change) => {
            const changeTypeVariant = 
              change.changeType === 'added' ? 'success' :
              change.changeType === 'removed' ? 'error' :
              'warning';
            
            const changeTypeLabel = 
              change.changeType === 'added' ? 'Added' :
              change.changeType === 'removed' ? 'Removed' :
              'Modified';
            
            const iconName = 
              change.type === 'component' ? 'cube' :
              change.category === 'colors' ? 'swatch' :
              change.category === 'typography' ? 'document-text' :
              change.category === 'spacing' ? 'arrows-pointing-out' :
              change.category === 'elevations' ? 'squares-2x2' :
              'clock';
            
            const item = document.createElement('div');
            item.className = 'change-item card p-5 hover:shadow-md transition-shadow';
            item.setAttribute('data-type', change.type || '');
            item.setAttribute('data-change-type', change.changeType || '');
            item.setAttribute('data-name', (change.name || '').toLowerCase());
            item.setAttribute('data-description', (change.description || '').toLowerCase());
            
            const timeStr = change.date 
              ? new Date(change.date).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
              : '';
            
            item.innerHTML = `
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 mt-1">
                  <div class="w-10 h-10 rounded-lg bg-muted flex items-center justify-center">
                    <i class="ti ti-${iconName} text-muted"></i>
                  </div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-2">
                    <h3 class="font-semibold text-base">${change.name || 'Unnamed'}</h3>
                    <span class="badge badge--${changeTypeVariant}">${changeTypeLabel}</span>
                    ${change.category && change.type === 'token' ? `<span class="badge badge--default">${change.category}</span>` : ''}
                  </div>
                  <p class="text-sm text-muted leading-relaxed">
                    ${change.description || 'No description available'}
                  </p>
                  ${timeStr ? `
                    <div class="mt-3 text-xs text-muted flex items-center gap-2">
                      <i class="ti ti-clock"></i>
                      <time datetime="${change.date}">${timeStr}</time>
                    </div>
                  ` : ''}
                </div>
              </div>
            `;
            
            itemsContainer.appendChild(item);
          });
          
          section.appendChild(itemsContainer);
          changesContainer.appendChild(section);
        });
        
        // Re-apply filters after content update
        setTimeout(() => {
          const filterChanges = window.filterChangesFunction;
          if (filterChanges) {
            filterChanges();
          }
        }, 50);
      }
      
      // Store filter function globally so it can be called after updates
      window.filterChangesFunction = undefined;
    }
    
    // Filter and search functionality
    (function() {
      // Wait for DOM to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFilters);
      } else {
        initFilters();
      }
      
      function initFilters() {
        // Get all required elements
        const searchInput = document.getElementById('search-input');
        const typeFilter = document.getElementById('type-filter');
        const changeFilter = document.getElementById('change-filter');
        const filterResults = document.getElementById('filter-results');
        const filterCount = document.getElementById('filter-count');
        const changesContainer = document.getElementById('changes-container');
        
        // Check if all required elements exist
        if (!searchInput || !typeFilter || !changeFilter || !filterResults || !filterCount || !changesContainer) {
          return;
        }
        
        // Restore filter state from localStorage
        const savedSearch = localStorage.getItem('updates-filter-search');
        const savedType = localStorage.getItem('updates-filter-type');
        const savedChange = localStorage.getItem('updates-filter-change');
        
        if (savedSearch !== null && searchInput instanceof HTMLInputElement) {
          searchInput.value = savedSearch;
        }
        if (savedType !== null && typeFilter instanceof HTMLSelectElement) {
          typeFilter.value = savedType;
        }
        if (savedChange !== null && changeFilter instanceof HTMLSelectElement) {
          changeFilter.value = savedChange;
        }
        
        function filterChanges() {
          // Re-query change items each time (in case DOM was updated dynamically)
          if (!changesContainer) return;
          const changeItems = Array.from(changesContainer.querySelectorAll('.change-item'));
          
          // If no change items, nothing to filter
          if (changeItems.length === 0) {
            return;
          }
          
          const searchTerm = (searchInput instanceof HTMLInputElement ? searchInput.value : '').toLowerCase().trim();
          const typeValue = typeFilter instanceof HTMLSelectElement ? typeFilter.value : 'all';
          const changeValue = changeFilter instanceof HTMLSelectElement ? changeFilter.value : 'all';
          
          // Save filter state to localStorage
          if (searchInput instanceof HTMLInputElement) {
            if (searchTerm) {
              localStorage.setItem('updates-filter-search', searchInput.value);
            } else {
              localStorage.removeItem('updates-filter-search');
            }
          }
          if (typeFilter instanceof HTMLSelectElement) {
            if (typeValue !== 'all') {
              localStorage.setItem('updates-filter-type', typeValue);
            } else {
              localStorage.removeItem('updates-filter-type');
            }
          }
          if (changeFilter instanceof HTMLSelectElement) {
            if (changeValue !== 'all') {
              localStorage.setItem('updates-filter-change', changeValue);
            } else {
              localStorage.removeItem('updates-filter-change');
            }
          }
          
          let visibleCount = 0;
          
          changeItems.forEach(item => {
            if (!(item instanceof HTMLElement)) return;
            
            const itemType = item.dataset.type || '';
            const itemChangeType = item.dataset.changeType || '';
            const itemName = item.dataset.name || '';
            const itemDescription = item.dataset.description || '';
            
            // Search filter
            const matchesSearch = !searchTerm || 
              itemName.includes(searchTerm) || 
              itemDescription.includes(searchTerm);
            
            // Type filter
            const matchesType = typeValue === 'all' || itemType === typeValue;
            
            // Change filter
            const matchesChange = changeValue === 'all' || itemChangeType === changeValue;
            
            const isVisible = matchesSearch && matchesType && matchesChange;
            
            if (isVisible) {
              item.style.display = '';
              visibleCount++;
            } else {
              item.style.display = 'none';
            }
          });
          
          // Update filter results
          if (searchTerm || typeValue !== 'all' || changeValue !== 'all') {
            if (filterResults instanceof HTMLElement) {
              filterResults.classList.remove('hidden');
            }
            if (filterCount instanceof HTMLElement) {
              filterCount.textContent = visibleCount.toString();
            }
          } else {
            if (filterResults instanceof HTMLElement) {
              filterResults.classList.add('hidden');
            }
          }
          
          // Hide empty date sections
          const dateSections = Array.from(changesContainer!.querySelectorAll('section'));
          dateSections.forEach(section => {
            if (!(section instanceof HTMLElement)) return;
            
            const visibleItems = Array.from(section.querySelectorAll('.change-item')).filter(
              item => item instanceof HTMLElement && item.style.display !== 'none'
            );
            if (visibleItems.length === 0) {
              section.style.display = 'none';
            } else {
              section.style.display = '';
            }
          });
        }
        
        // Attach event listeners
        searchInput.addEventListener('input', filterChanges);
        typeFilter.addEventListener('change', filterChanges);
        changeFilter.addEventListener('change', filterChanges);
        
        // Store filter function globally for use after dynamic updates
        window.filterChangesFunction = filterChanges;
        
        // Initial filter (applies saved filters or defaults)
        filterChanges();
      }
    })();
  </script>

  <style>
    .change-item {
      border-left: 3px solid transparent;
      transition: all 0.2s ease;
    }
    
    .change-item:hover {
      border-left-color: var(--theme-primary);
    }
    
    .change-item[data-change-type="added"] {
      border-left-color: var(--color-success);
    }
    
    .change-item[data-change-type="removed"] {
      border-left-color: var(--color-destructive);
    }
    
    .change-item[data-change-type="modified"] {
      border-left-color: var(--color-warning);
    }
    
  </style>
</DocsLayout>
