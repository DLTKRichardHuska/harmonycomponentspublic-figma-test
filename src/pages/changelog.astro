---
import { getCollection } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import ChangelogFilters from '../components/ChangelogFilters.astro';
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import {
  IN_PROGRESS_VERSION,
  compareSemverDesc,
  getBaseVersion,
  getVersionDisplayLabel,
  isSemverVersion,
} from '../lib/version';

const allEntries = await getCollection('changelog');

type ChangelogEntry = typeof allEntries[number];

function getDateKey(date: Date): string {
  return date.toISOString().split('T')[0];
}

const groupedByVersion = new Map<string, ChangelogEntry[]>();

for (const entry of allEntries) {
  const version = entry.data.version || IN_PROGRESS_VERSION;
  if (!groupedByVersion.has(version)) {
    groupedByVersion.set(version, []);
  }
  groupedByVersion.get(version)!.push(entry);
}

for (const entries of groupedByVersion.values()) {
  entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
}

const releasedVersions = [...groupedByVersion.keys()]
  .filter(isSemverVersion)
  .sort(compareSemverDesc);

const versionOrder: string[] = [];
if (groupedByVersion.has(IN_PROGRESS_VERSION)) {
  versionOrder.push(IN_PROGRESS_VERSION);
}
versionOrder.push(...releasedVersions);

for (const version of groupedByVersion.keys()) {
  if (!versionOrder.includes(version)) {
    versionOrder.push(version);
  }
}

const versionSections = versionOrder
  .filter((version) => groupedByVersion.has(version))
  .map((version) => {
    const entries = groupedByVersion.get(version)!;
    const dates = [...new Set(entries.map((entry) => getDateKey(entry.data.date)))].sort((a, b) =>
      b.localeCompare(a)
    );

    return {
      version,
      label: getVersionDisplayLabel(version),
      subtitle:
        version === IN_PROGRESS_VERSION
          ? `Changes not yet in an official release (since v${getBaseVersion()})`
          : undefined,
      entries,
      dates,
    };
  });

type CategoryKey = 'added' | 'changed' | 'deprecated' | 'removed' | 'fixed' | 'security';
const categoryConfig: Record<CategoryKey, { label: string; color: 'success' | 'info' | 'warning' | 'error' }> = {
  added: { label: 'Added', color: 'success' },
  changed: { label: 'Changed', color: 'info' },
  deprecated: { label: 'Deprecated', color: 'warning' },
  removed: { label: 'Removed', color: 'error' },
  fixed: { label: 'Fixed', color: 'success' },
  security: { label: 'Security', color: 'error' },
};

const filterVersions = versionSections.map((section) => ({
  value: section.version,
  label: section.label,
}));
---

<DocsLayout title="Changelog">
  <div class="changelog-page">
    <header class="changelog-header">
      <h1>Changelog</h1>
      <p class="changelog-description">
        All notable changes to the Harmony Design System are documented here by version.
        This changelog follows <a href="https://keepachangelog.com/" target="_blank" rel="noopener">Keep a Changelog</a> format
        and adheres to <a href="https://semver.org/" target="_blank" rel="noopener">Semantic Versioning</a>.
      </p>
    </header>

    {allEntries.length > 0 ? (
      <>
        <ChangelogFilters entries={allEntries} versions={filterVersions} />

        <div class="changelog-timeline" id="changelog-entries">
          {versionSections.map((section) => (
            <section class="version-section" data-version={section.version}>
              <div class="version-header">
                <h2 class="version-title">{section.label}</h2>
                {section.subtitle && <p class="version-subtitle">{section.subtitle}</p>}
                <span class="version-count">
                  {section.entries.length} {section.entries.length === 1 ? 'entry' : 'entries'}
                </span>
              </div>

              {section.dates.map((dateKey) => {
                const dateEntries = section.entries.filter(
                  (entry) => getDateKey(entry.data.date) === dateKey
                );
                const entryDate = dateEntries[0]?.data.date;

                return (
                  <div class="date-section">
                    <div class="date-header">
                      <div class="version-meta">
                        {entryDate && (
                          <time class="version-date" datetime={entryDate.toISOString()}>
                            {entryDate.toLocaleDateString('en-US', {
                              year: 'numeric',
                              month: 'long',
                              day: 'numeric',
                            })}
                          </time>
                        )}
                        <span class="version-count">
                          ({dateEntries.length} {dateEntries.length === 1 ? 'entry' : 'entries'})
                        </span>
                      </div>
                    </div>

                    <div class="version-content">
                      <ul class="changelog-entries">
                        {dateEntries.map((entry) => {
                          const config = categoryConfig[entry.data.category as CategoryKey];
                          return (
                            <li
                              class="changelog-entry"
                              data-version={entry.data.version}
                              data-category={entry.data.category}
                              data-type={entry.data.type}
                              data-target={entry.data.target}
                              data-breaking={entry.data.breaking ? 'true' : 'false'}
                            >
                              <div class="entry-content">
                                <Badge variant={config.color} class="entry-category-badge">
                                  {config.label}
                                </Badge>
                                <strong class="entry-target">{entry.data.target}:</strong>
                                <span class="entry-description">{entry.data.description}</span>
                                {entry.data.breaking && (
                                  <Badge variant="error">Breaking</Badge>
                                )}
                              </div>

                              {entry.data.properties && entry.data.properties.length > 0 && (
                                <ul class="entry-properties">
                                  {entry.data.properties.map((prop) => (
                                    <li>
                                      <code>{prop.name}</code>: {prop.change}
                                      {prop.before && prop.after && (
                                        <span> ({prop.before} → {prop.after})</span>
                                      )}
                                    </li>
                                  ))}
                                </ul>
                              )}

                              <div class="entry-meta">
                                <time class="entry-timestamp" datetime={entry.data.date.toISOString()}>
                                  {entry.data.date.toLocaleString('en-US', {
                                    year: 'numeric',
                                    month: 'short',
                                    day: 'numeric',
                                    hour: '2-digit',
                                    minute: '2-digit',
                                    timeZone: 'America/Denver',
                                  })}
                                </time>
                                {entry.data.commit && (
                                  <>
                                    <span class="entry-meta-separator">·</span>
                                    <span class="commit-hash" title={entry.data.commit.message}>
                                      {entry.data.commit.hash}
                                    </span>
                                    <span class="commit-author">
                                      by {entry.data.commit.author}
                                    </span>
                                  </>
                                )}
                              </div>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </div>
                );
              })}
            </section>
          ))}
        </div>
      </>
    ) : (
      <Card elevated>
        <div class="changelog-empty">
          <p>No changelog entries yet.</p>
          <p>
            Changes are tracked automatically when component, token, or layout files change on a branch.
            Official versions appear here after a GitHub Release is published.
          </p>
          <details class="changelog-empty-details">
            <summary>How does it work?</summary>
            <ul>
              <li>Work on a feature branch and open a pull request to <code>main</code></li>
              <li>GitHub Actions detects component/token changes and updates changelog data on your branch</li>
              <li>After merge, publish a GitHub Release from <code>main</code> to create the next official version</li>
            </ul>
          </details>
        </div>
      </Card>
    )}
  </div>
</DocsLayout>

<style>
  .changelog-page {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-6, 24px);
  }

  .changelog-header {
    margin-bottom: var(--spacing-8, 32px);
  }

  .changelog-header h1 {
    font-size: var(--font-size-display-sm, 2.5rem);
    margin-bottom: var(--spacing-4, 16px);
    font-weight: 700;
  }

  .changelog-description {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-4, 16px);
  }

  .changelog-description a {
    color: var(--theme-primary);
    text-decoration: underline;
  }

  .version-section {
    margin-bottom: var(--spacing-10, 40px);
    border-left: 2px solid var(--border-color);
    padding-left: var(--spacing-6, 24px);
    position: relative;
  }

  .version-section::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 6px;
    width: 12px;
    height: 12px;
    background: var(--theme-primary);
    border-radius: 50%;
    border: 2px solid var(--card-bg);
  }

  .version-header {
    margin-bottom: var(--spacing-6, 24px);
  }

  .version-title {
    font-size: var(--font-size-heading-lg, 1.75rem);
    margin-bottom: var(--spacing-2, 8px);
    font-weight: 600;
  }

  .version-subtitle {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-2, 8px);
  }

  .date-section {
    margin-bottom: var(--spacing-8, 32px);
  }

  .date-section:last-child {
    margin-bottom: 0;
  }

  .date-header {
    margin-bottom: var(--spacing-6, 24px);
  }

  .version-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-3, 12px);
    flex-wrap: wrap;
  }

  .version-date {
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
  }

  .date-header .version-date {
    font-size: var(--font-size-body, 1rem);
    font-weight: 500;
  }

  .version-count {
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
    font-weight: 500;
  }

  .date-header .version-count {
    font-size: var(--font-size-body, 1rem);
  }

  .changelog-entries {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .changelog-entry {
    padding: var(--spacing-4, 16px) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .changelog-entry:last-child {
    border-bottom: none;
  }

  .entry-content {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-2, 8px);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2, 8px);
  }

  .entry-category-badge {
    flex-shrink: 0;
  }

  .entry-target {
    color: var(--text-primary);
    font-weight: 600;
  }

  .entry-description {
    color: var(--text-secondary);
    flex: 1;
  }

  .entry-properties {
    margin-top: var(--spacing-2, 8px);
    margin-left: var(--spacing-4, 16px);
    list-style: disc;
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm, 0.875rem);
  }

  .entry-properties code {
    background: var(--elevated-bg);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.875em;
  }

  .entry-meta {
    margin-top: var(--spacing-2, 8px);
    font-size: var(--font-size-body-sm, 0.875rem);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: var(--spacing-2, 8px);
    flex-wrap: wrap;
  }

  .entry-timestamp {
    color: var(--text-muted);
  }

  .entry-meta-separator {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .commit-hash {
    font-family: monospace;
    background: var(--elevated-bg);
    padding: 2px 6px;
    border-radius: 3px;
    cursor: help;
  }

  .changelog-empty {
    text-align: center;
    padding: var(--spacing-10, 40px);
  }

  .changelog-empty p {
    margin-bottom: var(--spacing-3, 12px);
    color: var(--text-secondary);
  }

  .changelog-empty code {
    background: var(--elevated-bg);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: monospace;
    border: 1px solid var(--border-color);
  }

  .changelog-empty-details {
    margin-top: var(--spacing-4, 16px);
    padding: var(--spacing-3, 12px);
    background: var(--elevated-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-md, 6px);
  }

  .changelog-empty-details summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--theme-primary);
  }

  .changelog-empty-details ul {
    margin-top: var(--spacing-2, 8px);
    padding-left: var(--spacing-4, 16px);
  }
</style>
