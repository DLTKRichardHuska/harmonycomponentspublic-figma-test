---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Floating Nav" description="CP-specific floating navigation component.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">Floating Nav</h1>
        <span class="badge badge--primary">CP Only</span>
      </div>
      <p class="page-header__description">
        A floating navigation component specific to the Costpoint (CP) theme for quick access to common actions.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Examples</h2>
      
      <ExampleSection title="Floating Action Bar" description="Fixed action bar for quick access.">
        <div class="relative h-64 border rounded-lg bg-page overflow-hidden">
          <div class="p-4">
            <p class="text-secondary">Content area. The floating nav appears at the bottom.</p>
          </div>
          
          <!-- Floating Nav -->
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2">
            <div class="flex items-center gap-2 bg-card border rounded-full shadow-lg px-4 py-2">
              <button class="icon-btn"><i class="ti ti-home icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-search icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-plus icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-bell icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-user icon-btn__icon"></i></button>
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Side Floating Nav" description="Floating nav on the side of the screen.">
        <div class="relative h-64 border rounded-lg bg-page overflow-hidden">
          <div class="p-4">
            <p class="text-secondary">Content area. The floating nav appears on the right side.</p>
          </div>
          
          <!-- Side Floating Nav -->
          <div class="absolute right-4 top-1/2 -translate-y-1/2">
            <div class="flex flex-col gap-2 bg-card border rounded-xl shadow-lg p-2">
              <button class="icon-btn"><i class="ti ti-home icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-folder icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-settings icon-btn__icon"></i></button>
              <button class="icon-btn"><i class="ti ti-help icon-btn__icon"></i></button>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section class="space-y-6">
      <h2 class="section__title">Usage Notes</h2>
      <div class="a11y-card">
        <h3 class="a11y-card__title">
          <i class="ti ti-info-circle a11y-card__title-icon"></i>
          CP Theme Only
        </h3>
        <p class="a11y-card__text">
          This component is specific to the Costpoint (CP) theme. It will only appear in the navigation when the CP theme is active.
        </p>
      </div>
    </section>
  </article>
</DocsLayout>
