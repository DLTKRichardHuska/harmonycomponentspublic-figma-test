---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
import PropsTable from '../../components/PropsTable.astro';
import Label from '../../components/ui/Label.astro';
import Input from '../../components/ui/Input.astro';
import DateInput from '../../components/ui/DateInput.astro';

const props = [
  { name: 'type', type: "'date' | 'datetime-local' | 'time' | 'month' | 'week'", default: "'date'", description: 'Type of date/time input' },
  { name: 'value', type: 'string', default: '—', description: 'Current value in ISO format' },
  { name: 'min', type: 'string', default: '—', description: 'Minimum allowed date' },
  { name: 'max', type: 'string', default: '—', description: 'Maximum allowed date' },
  { name: 'disabled', type: 'boolean', default: 'false', description: 'Disables the input' },
  { name: 'required', type: 'boolean', default: 'false', description: 'Makes the field required' },
  { name: 'error', type: 'boolean', default: 'false', description: 'Shows error state' },
  { name: 'errorMessage', type: 'string', default: '—', description: 'Error message to display' },
];
---

<DocsLayout title="Date Picker" description="Calendar date selection component.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Date Picker</h1>
        <span class="text-xs px-2 py-1 rounded-full border bg-success/10 text-success border-success/30">stable</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Date picker allows users to select dates from a calendar interface. Click the calendar icon or the input field to open the date picker.
      </p>
    </header>

    <nav class="flex gap-4 text-sm">
      <a href="#examples" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-eye"></i> Examples</a>
      <a href="#props" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-list"></i> Props</a>
      <a href="#usage" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-book"></i> Usage</a>
      <a href="#accessibility" class="text-theme-primary hover:underline flex items-center gap-1"><i class="ti ti-accessible"></i> Accessibility</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Examples</h2>

      <ExampleSection title="Basic Date Input" description="Click the input or calendar icon to open the native date picker.">
        <div class="max-w-xs space-y-2">
          <Label for="date-basic">Select Date</Label>
          <DateInput id="date-basic" />
        </div>
      </ExampleSection>

      <ExampleSection title="With Default Value" description="Pre-populated date value.">
        <div class="max-w-xs space-y-2">
          <Label for="date-default">Start Date</Label>
          <DateInput id="date-default" value="2024-01-15" />
        </div>
      </ExampleSection>

      <ExampleSection title="Date Range" description="Select dates within a specific range.">
        <div class="grid sm:grid-cols-2 gap-4 max-w-md">
          <div class="space-y-2">
            <Label for="date-start">Start Date</Label>
            <DateInput id="date-start" min="2024-01-01" max="2024-12-31" />
          </div>
          <div class="space-y-2">
            <Label for="date-end">End Date</Label>
            <DateInput id="date-end" min="2024-01-01" max="2024-12-31" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Date and Time" description="Combined date and time selection.">
        <div class="max-w-xs space-y-2">
          <Label for="datetime-input">Event Date & Time</Label>
          <DateInput type="datetime-local" id="datetime-input" />
        </div>
      </ExampleSection>

      <ExampleSection title="Time Only" description="Time selection without date.">
        <div class="max-w-xs space-y-2">
          <Label for="time-input">Meeting Time</Label>
          <DateInput type="time" id="time-input" />
        </div>
      </ExampleSection>

      <ExampleSection title="Month Picker" description="Select a specific month.">
        <div class="max-w-xs space-y-2">
          <Label for="month-input">Billing Month</Label>
          <DateInput type="month" id="month-input" />
        </div>
      </ExampleSection>

      <ExampleSection title="Week Picker" description="Select a specific week.">
        <div class="max-w-xs space-y-2">
          <Label for="week-input">Report Week</Label>
          <DateInput type="week" id="week-input" />
        </div>
      </ExampleSection>

      <ExampleSection title="States" description="Different date input states.">
        <div class="grid sm:grid-cols-2 gap-4 max-w-md">
          <div class="space-y-2">
            <Label for="date-disabled">Disabled</Label>
            <DateInput id="date-disabled" value="2024-01-15" disabled />
          </div>
          <div class="space-y-2">
            <Label for="date-error">Error State</Label>
            <DateInput id="date-error" error errorMessage="Please select a valid date" />
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="In a Form" description="Date picker used within a form context.">
        <div class="max-w-md p-6 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-4">Event Details</h3>
          <div class="space-y-4">
            <div class="space-y-2">
              <Label for="event-name" required>Event Name</Label>
              <Input id="event-name" placeholder="Enter event name" />
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="space-y-2">
                <Label for="event-date" required>Date</Label>
                <DateInput id="event-date" required />
              </div>
              <div class="space-y-2">
                <Label for="event-time" required>Time</Label>
                <DateInput type="time" id="event-time" required />
              </div>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>

    <section id="props">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Props</h2>
      <PropsTable props={props} />
    </section>

    <section id="usage">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Usage Guidelines</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-success/30 bg-success/5">
          <h3 class="font-semibold text-success mb-3 flex items-center gap-2"><i class="ti ti-check"></i> Do</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Use appropriate date format for your locale</li>
            <li>• Set reasonable min/max constraints</li>
            <li>• Provide clear labels indicating expected format</li>
            <li>• Use datetime-local for events requiring time</li>
            <li>• Show error messages for invalid dates</li>
          </ul>
        </div>
        <div class="p-6 rounded-lg border border-error/30 bg-error/5">
          <h3 class="font-semibold text-error mb-3 flex items-center gap-2"><i class="ti ti-x"></i> Don't</h3>
          <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
            <li>• Allow dates outside valid ranges</li>
            <li>• Use text inputs for date selection</li>
            <li>• Forget to handle timezone differences</li>
            <li>• Mix date formats inconsistently</li>
            <li>• Hide the calendar picker icon</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="accessibility">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Accessibility</h2>
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-keyboard text-theme-primary"></i>
            Keyboard Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Native date inputs support keyboard navigation. Use arrow keys to change values and Enter to confirm selection.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-tag text-theme-primary"></i>
            Labels
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Always associate date inputs with labels using the <code>for</code> attribute to ensure screen readers announce them correctly.
          </p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-surface/50">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
            <i class="ti ti-device-mobile text-theme-primary"></i>
            Mobile Support
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            Native date inputs display platform-specific date pickers on mobile devices, providing familiar interfaces for users.
          </p>
        </div>
      </div>
    </section>
  </article>
</DocsLayout>
