---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="List Menu" description="Vertical list menu for navigation.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="page-header__title page-header__title--sm">List Menu</h1>
        <span class="badge badge--success">stable</span>
      </div>
      <p class="page-header__description">
        List menus display a vertical list of interactive items for navigation or selection.
      </p>
    </header>

    <nav class="article-nav">
      <a href="#examples" class="article-nav__link"><i class="ti ti-eye"></i> Examples</a>
    </nav>

    <section id="examples" class="space-y-8">
      <h2 class="section__title">Examples</h2>

      <ExampleSection title="Basic List Menu" description="Standard navigation menu.">
        <div class="max-w-xs">
          <div class="list-menu">
            <button class="list-menu__item is-active">
              <i class="ti ti-home list-menu__item-icon"></i>
              Dashboard
            </button>
            <button class="list-menu__item">
              <i class="ti ti-user list-menu__item-icon"></i>
              Profile
            </button>
            <button class="list-menu__item">
              <i class="ti ti-settings list-menu__item-icon"></i>
              Settings
            </button>
            <button class="list-menu__item">
              <i class="ti ti-logout list-menu__item-icon"></i>
              Logout
            </button>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="With Links" description="Menu as navigation links.">
        <div class="max-w-xs">
          <nav class="list-menu">
            <a href="#" class="list-menu__item is-active">
              <i class="ti ti-file list-menu__item-icon"></i>
              Documents
            </a>
            <a href="#" class="list-menu__item">
              <i class="ti ti-photo list-menu__item-icon"></i>
              Images
            </a>
            <a href="#" class="list-menu__item">
              <i class="ti ti-movie list-menu__item-icon"></i>
              Videos
            </a>
            <a href="#" class="list-menu__item">
              <i class="ti ti-music list-menu__item-icon"></i>
              Audio
            </a>
          </nav>
        </div>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
