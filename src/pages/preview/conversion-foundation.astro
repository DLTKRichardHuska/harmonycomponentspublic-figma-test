---
/**
 * Conversion verification capture fixture — foundation tokens and typography.
 * Access at: /preview/conversion-foundation
 */
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem('theme') || 'light';
        const savedColorTheme = localStorage.getItem('colorTheme') || 'cp';
        if (savedTheme === 'dark') document.documentElement.classList.add('dark');
        document.documentElement.classList.add('theme-' + savedColorTheme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Conversion Foundation Capture</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; padding: 48px; font-family: var(--font-family-body, Figtree, sans-serif); }
      #conversion-capture-root { display: flex; flex-direction: column; gap: 32px; max-width: 960px; }
      .capture-section { display: flex; flex-direction: column; gap: 12px; }
      .capture-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); }
      .swatch-row { display: flex; flex-wrap: wrap; gap: 12px; }
      .swatch {
        width: 96px; height: 56px; border-radius: 8px; border: 1px solid var(--border-default);
        display: flex; align-items: flex-end; padding: 6px; font-size: 0.65rem;
      }
      .swatch--primary { background: var(--color-primary); color: var(--color-on-primary); }
      .swatch--surface { background: var(--color-surface); color: var(--text-primary); }
      .swatch--error { background: var(--color-error); color: var(--color-on-error); }
      .type-sample--display { font: var(--font-display-lg); color: var(--text-primary); }
      .type-sample--body { font: var(--font-body-md); color: var(--text-secondary); }
      .type-sample--label { font: var(--font-label-sm); color: var(--text-muted); }
    </style>
  </head>
  <body>
    <div id="conversion-capture-root" data-capture-scope="foundation">
      <div class="capture-section">
        <span class="capture-label">Semantic colors</span>
        <div class="swatch-row">
          <div class="swatch swatch--primary">primary</div>
          <div class="swatch swatch--surface">surface</div>
          <div class="swatch swatch--error">error</div>
        </div>
      </div>
      <div class="capture-section">
        <span class="capture-label">Typography</span>
        <p class="type-sample--display">Display heading sample</p>
        <p class="type-sample--body">Body text sample for conversion verification.</p>
        <p class="type-sample--label">Label text sample</p>
      </div>
    </div>
  </body>
</html>
