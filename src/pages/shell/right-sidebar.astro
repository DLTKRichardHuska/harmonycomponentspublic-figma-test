---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Right Sidebar" description="Secondary sidebar for contextual content.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Right Sidebar</h1>
      <p class="page-header__description">
        The right sidebar displays contextual information, details panels, or secondary navigation.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Sidebar Examples</h2>
      
      <ExampleSection title="Details Panel" description="Sidebar showing item details.">
        <div class="w-72 border rounded-lg overflow-hidden">
          <div class="bg-nav">
            <div class="p-4 border-b">
              <h3 class="font-semibold text-primary">Details</h3>
            </div>
            <div class="p-4 space-y-4">
              <div>
                <div class="text-xs text-muted mb-1">Status</div>
                <span class="badge badge--success">Active</span>
              </div>
              <div>
                <div class="text-xs text-muted mb-1">Created</div>
                <div class="text-sm text-primary">Jan 15, 2024</div>
              </div>
              <div>
                <div class="text-xs text-muted mb-1">Owner</div>
                <div class="text-sm text-primary">John Doe</div>
              </div>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
