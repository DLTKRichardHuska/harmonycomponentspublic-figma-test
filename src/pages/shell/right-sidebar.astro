---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Right Sidebar" description="Contextual actions and utility panel with three sections.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Right Sidebar</h1>
        <span class="text-xs px-2 py-1 bg-theme-primary/10 text-theme-primary rounded">CP/VP</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Contextual actions sidebar with three stacked panels for branding, tools, and settings. Docked to the right edge.
      </p>
    </header>

    <!-- Live Example -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Visual Example</h2>
      
      <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-obsidian">
        <div class="flex justify-end">
          <!-- Right Sidebar -->
          <div class="space-y-2">
            <span class="text-xs font-mono text-slate-500 dark:text-slate-400">52px width</span>
            <div class="flex flex-col gap-3 w-[52px]">
              <!-- Panel 1: Logo + Notifications -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2 flex flex-col gap-2 items-center" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <!-- Deltek Logo -->
                <div class="w-9 h-9 flex items-center justify-center">
                  <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none">
                    <text x="4" y="22" font-size="12" font-weight="bold" fill="#6366f1">D</text>
                    <text x="12" y="16" font-size="8" fill="#a855f7">+</text>
                  </svg>
                </div>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                  </svg>
                </button>
              </div>
              
              <!-- Panel 2: Tools -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2 flex flex-col gap-2 items-center" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                  </svg>
                </button>
              </div>
              
              <!-- Panel 3: Settings & Help -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2 flex flex-col gap-2 items-center" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 3l8.735 8.735m0 0a.374.374 0 11.53.53m-.53-.53l.53.53m0 0L21 21M14.652 9.348a3.75 3.75 0 010 5.304m2.121-7.425a6.75 6.75 0 010 9.546m2.121-11.667c3.808 3.807 3.808 9.98 0 13.788m-9.546-4.242a3.733 3.733 0 01-1.06-2.122m-1.061 4.243a6.75 6.75 0 01-1.625-6.929m-.496 9.05c-3.068-3.067-3.664-7.67-1.79-11.334M12 12h.008v.008H12V12z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Structure -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Structure</h2>
      
      <div class="grid md:grid-cols-3 gap-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-theme-primary/20 text-theme-primary text-xs flex items-center justify-center font-mono">1</span>
            Panel 1: Branding
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">Logo and notifications:</p>
          <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
            <li class="flex items-center gap-2">
              <span class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">Logo</span>
              Deltek/Product logo
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">bell</code>
              Notifications
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">arrow-up-tray</code>
              Files/Upload
            </li>
          </ul>
        </div>
        
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-theme-primary/20 text-theme-primary text-xs flex items-center justify-center font-mono">2</span>
            Panel 2: Tools
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">Output and layout tools:</p>
          <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">printer</code>
              Print
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">squares-2x2</code>
              Layout/Template
            </li>
          </ul>
        </div>
        
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-theme-primary/20 text-theme-primary text-xs flex items-center justify-center font-mono">3</span>
            Panel 3: Settings
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">System and help:</p>
          <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">microphone</code>
              Voice (disabled state)
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">signal-slash</code>
              Offline indicator
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">ellipsis-horizontal-circle</code>
              More actions
            </li>
            <li class="flex items-center gap-2">
              <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">question-mark-circle</code>
              Help
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Code Example -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Code Example</h2>
      
      <CodeBlock 
        language="html"
        filename="right-sidebar.html"
        code={`<!-- Right Sidebar - Docked to right edge -->
<aside class="w-[52px] flex flex-col gap-3 shrink-0 pt-2">
  <!-- Panel 1: Branding & Notifications -->
  <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2
              shadow-[0px_12px_40px_rgba(16,24,64,0.24)]">
    <div class="flex flex-col gap-2 items-center">
      <!-- Product Logo -->
      <div class="w-9 h-9 flex items-center justify-center">
        <img src="/logos/deltek-logo.svg" alt="Logo" class="w-8 h-8" />
      </div>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Notifications">
        <!-- bell icon -->
      </button>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Files">
        <!-- arrow-up-tray icon -->
      </button>
    </div>
  </div>
  
  <!-- Panel 2: Tools -->
  <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2
              shadow-[0px_12px_40px_rgba(16,24,64,0.24)]">
    <div class="flex flex-col gap-2 items-center">
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Print">
        <!-- printer icon -->
      </button>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Layout">
        <!-- squares-2x2/template icon -->
      </button>
    </div>
  </div>
  
  <!-- Panel 3: Settings & Help -->
  <div class="bg-[#fcfdff] dark:bg-surface rounded-tl-xl rounded-bl-xl py-3 px-2 flex-1
              shadow-[0px_12px_40px_rgba(16,24,64,0.24)]">
    <div class="flex flex-col gap-2 items-center">
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Voice">
        <!-- microphone icon -->
      </button>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Offline">
        <!-- signal-slash icon -->
      </button>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="More">
        <!-- ellipsis-horizontal-circle icon -->
      </button>
      <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800" aria-label="Help">
        <!-- question-mark-circle icon -->
      </button>
    </div>
  </div>
</aside>`}
      />
    </section>

    <!-- Specifications -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Specifications</h2>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <th class="text-left py-3 px-4 font-medium text-slate-900 dark:text-white">Property</th>
              <th class="text-left py-3 px-4 font-medium text-slate-900 dark:text-white">Value</th>
            </tr>
          </thead>
          <tbody class="text-slate-600 dark:text-slate-400">
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Width</td>
              <td class="py-3 px-4 font-mono text-xs">52px</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Panel background</td>
              <td class="py-3 px-4 font-mono text-xs">#fcfdff</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Border radius</td>
              <td class="py-3 px-4 font-mono text-xs">12px (rounded-tl-xl rounded-bl-xl)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Shadow</td>
              <td class="py-3 px-4 font-mono text-xs">0px 12px 40px rgba(16,24,64,0.24)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Gap between panels</td>
              <td class="py-3 px-4 font-mono text-xs">12px (gap-3)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Icon size</td>
              <td class="py-3 px-4 font-mono text-xs">24px (w-6 h-6)</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Icon padding</td>
              <td class="py-3 px-4 font-mono text-xs">6px (p-1.5)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Behavior -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Behavior</h2>
      
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
          <h4 class="font-medium text-slate-900 dark:text-white mb-2">Docked Position</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">The sidebar is docked flush to the right edge of the viewport. Only the inner (left) corners are rounded.</p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
          <h4 class="font-medium text-slate-900 dark:text-white mb-2">Header Gap</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">An 8px gap separates the sidebar panels from the header. Panels do not touch the top of the viewport.</p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
          <h4 class="font-medium text-slate-900 dark:text-white mb-2">Icon-Only Display</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">Unlike the left sidebar, the right sidebar remains icon-only and does not expand on hover. Use tooltips for additional context.</p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
          <h4 class="font-medium text-slate-900 dark:text-white mb-2">Contextual Actions</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">Icons may trigger slide-out panels, modals, or dropdown menus for additional functionality.</p>
        </div>
      </div>
    </section>

    <!-- Accessibility -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Accessibility</h2>
      <ul class="space-y-2 text-sm text-slate-600 dark:text-slate-400">
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          All icon buttons must have <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">aria-label</code> for screen readers
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Provide visible tooltips on hover/focus for icon identification
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Ensure adequate color contrast for icons (minimum 3:1 ratio)
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
          </svg>
          Keyboard navigation should follow a logical order through all three panels
        </li>
      </ul>
    </section>
  </article>
</DocsLayout>
