---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';
---

<DocsLayout title="Left Sidebar" description="Primary navigation sidebar with icon menu and expandable sections.">
  <article class="space-y-12">
    <header class="border-b border-slate-200 dark:border-slate-800 pb-8">
      <div class="flex items-center gap-3 mb-4">
        <h1 class="font-display text-4xl font-bold text-slate-900 dark:text-white">Left Sidebar</h1>
        <span class="text-xs px-2 py-1 bg-theme-primary/10 text-theme-primary rounded">CP/VP</span>
      </div>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
        Primary navigation sidebar with icon menu and expandable sections. Docked to the left edge with two stacked panels.
      </p>
    </header>

    <!-- Live Example -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Visual Example</h2>
      
      <div class="p-6 rounded-lg border border-slate-200 dark:border-slate-800 bg-slate-100 dark:bg-obsidian">
        <div class="flex gap-6">
          <!-- Collapsed State -->
          <div class="space-y-2">
            <span class="text-xs font-mono text-slate-500 dark:text-slate-400">Collapsed (52px)</span>
            <div class="flex flex-col gap-4 w-[52px]">
              <!-- Panel 1 -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tr-xl rounded-br-xl py-2 px-2 flex flex-col gap-4 items-center" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </button>
              </div>
              
              <!-- Panel 2 -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tr-xl rounded-br-xl py-2 px-2 flex flex-col gap-4 items-center" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                  </svg>
                </button>
                <!-- Divider -->
                <div class="w-9 h-px bg-slate-200 dark:bg-slate-700"></div>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 0 1-1.125-1.125v-3.75ZM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-8.25ZM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 0 1-1.125-1.125v-2.25Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18Zm2.498-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM8.25 6h7.5v2.25h-7.5V6ZM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 0 0 2.25 2.25h10.5a2.25 2.25 0 0 0 2.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0 0 12 2.25Z" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                  </svg>
                </button>
                <button class="p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
          
          <!-- Expanded State (Hover) -->
          <div class="space-y-2">
            <span class="text-xs font-mono text-slate-500 dark:text-slate-400">Expanded (on hover)</span>
            <div class="flex flex-col gap-4 w-48">
              <!-- Panel 1 Expanded -->
              <div class="bg-[#fcfdff] dark:bg-surface rounded-tr-xl rounded-br-xl py-2 px-2 flex flex-col gap-1" style="box-shadow: 0px 12px 40px rgba(16,24,64,0.24);">
                <button class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors w-full text-left">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                  </svg>
                  <span class="text-sm text-slate-700 dark:text-slate-300">Home</span>
                </button>
                <button class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors w-full text-left">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                  </svg>
                  <span class="text-sm text-slate-700 dark:text-slate-300">Apps</span>
                </button>
                <button class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors w-full text-left">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                  </svg>
                  <span class="text-sm text-slate-700 dark:text-slate-300">Favorites</span>
                </button>
                <button class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors w-full text-left">
                  <svg class="w-6 h-6 text-slate-600 dark:text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  <span class="text-sm text-slate-700 dark:text-slate-300">Recent</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Structure -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Structure</h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-theme-primary/20 text-theme-primary text-xs flex items-center justify-center font-mono">1</span>
            Panel 1: Primary Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">Quick access navigation icons:</p>
          <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">home</code> Home</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">squares-2x2</code> Apps</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">star</code> Favorites</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">clock</code> Recent</li>
          </ul>
        </div>
        
        <div class="p-4 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-surface">
          <h3 class="font-semibold text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <span class="w-6 h-6 rounded bg-theme-primary/20 text-theme-primary text-xs flex items-center justify-center font-mono">2</span>
            Panel 2: Module Navigation
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">Module and tool icons with divider:</p>
          <ul class="text-sm text-slate-600 dark:text-slate-400 space-y-1">
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">magnifying-glass</code> Search</li>
            <li class="text-xs text-slate-400">— Divider —</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">rectangle-group</code> Layouts</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">calculator</code> Calculator</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">arrow-up-tray</code> Export</li>
            <li class="flex items-center gap-2"><code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">chart-bar</code> Analytics</li>
            <li class="text-xs text-slate-400">+ more...</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Code Example -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Code Example</h2>
      
      <CodeBlock 
        language="html"
        filename="left-sidebar.html"
        code={`<!-- Left Sidebar - Docked to left edge -->
<aside class="w-[52px] hover:w-48 transition-all duration-200 flex flex-col gap-4 shrink-0 pt-2">
  <!-- Panel 1: Primary Navigation -->
  <div class="bg-[#fcfdff] dark:bg-surface rounded-tr-xl rounded-br-xl py-2 px-2 
              shadow-[0px_12px_40px_rgba(16,24,64,0.24)]">
    <nav class="flex flex-col gap-4 items-center">
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 group">
        <svg class="w-6 h-6 text-slate-600 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <!-- home icon -->
        </svg>
        <span class="nav-label hidden group-hover:inline text-sm">Home</span>
      </a>
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <!-- squares-2x2 icon - Apps -->
      </a>
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <!-- star icon - Favorites -->
      </a>
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <!-- clock icon - Recent -->
      </a>
    </nav>
  </div>
  
  <!-- Panel 2: Module Navigation -->
  <div class="bg-[#fcfdff] dark:bg-surface rounded-tr-xl rounded-br-xl py-2 px-2 flex-1
              shadow-[0px_12px_40px_rgba(16,24,64,0.24)]">
    <nav class="flex flex-col gap-4 items-center">
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <!-- magnifying-glass icon - Search -->
      </a>
      <!-- Divider -->
      <div class="w-9 h-px bg-slate-200 dark:bg-slate-700"></div>
      <a href="#" class="nav-btn p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <!-- rectangle-group icon -->
      </a>
      <!-- More navigation items... -->
    </nav>
  </div>
</aside>`}
      />
    </section>

    <!-- Specifications -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Specifications</h2>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 dark:border-slate-700">
              <th class="text-left py-3 px-4 font-medium text-slate-900 dark:text-white">Property</th>
              <th class="text-left py-3 px-4 font-medium text-slate-900 dark:text-white">Value</th>
            </tr>
          </thead>
          <tbody class="text-slate-600 dark:text-slate-400">
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Width (collapsed)</td>
              <td class="py-3 px-4 font-mono text-xs">52px</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Width (expanded)</td>
              <td class="py-3 px-4 font-mono text-xs">~192px (w-48)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Panel background</td>
              <td class="py-3 px-4 font-mono text-xs">#fcfdff</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Border radius</td>
              <td class="py-3 px-4 font-mono text-xs">12px (rounded-tr-xl rounded-br-xl)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Shadow</td>
              <td class="py-3 px-4 font-mono text-xs">0px 12px 40px rgba(16,24,64,0.24)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Gap between panels</td>
              <td class="py-3 px-4 font-mono text-xs">16px (gap-4)</td>
            </tr>
            <tr class="border-b border-slate-100 dark:border-slate-800">
              <td class="py-3 px-4">Icon size</td>
              <td class="py-3 px-4 font-mono text-xs">24px (w-6 h-6)</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Icon padding</td>
              <td class="py-3 px-4 font-mono text-xs">6px (p-1.5)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Behavior -->
    <section class="space-y-4">
      <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Behavior</h2>
      
      <div class="space-y-4">
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
          <h4 class="font-medium text-slate-900 dark:text-white mb-2">Hover Expansion</h4>
          <p class="text-sm text-slate-600 dark:text-slate-400">On hover, the sidebar expands to reveal text labels alongside icons. Use <code class="text-xs bg-slate-100 dark:bg-slate-800 px-1 rounded">transition-all duration-200</code> for smooth animation.</p>
        </div>
        <div class="p-4 rounded-lg border border-slate-200 dark:border-border bg-white dark:bg-surface">
