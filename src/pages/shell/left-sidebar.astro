---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Left Sidebar" description="Navigation sidebar component.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Left Sidebar</h1>
      <p class="page-header__description">
        The left sidebar provides the main navigation structure for the application.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Sidebar Structure</h2>
      
      <ExampleSection title="Navigation Sidebar" description="Sidebar with grouped navigation items.">
        <div class="w-64 border rounded-lg overflow-hidden">
          <div class="bg-nav p-4">
            <div class="text-xs text-muted uppercase tracking-widest mb-3">Navigation</div>
            <nav class="space-y-1">
              <a href="#" class="nav__item is-active">
                <i class="ti ti-home nav__item-icon"></i>
                Dashboard
              </a>
              <a href="#" class="nav__item">
                <i class="ti ti-folder nav__item-icon"></i>
                Projects
              </a>
              <a href="#" class="nav__item">
                <i class="ti ti-users nav__item-icon"></i>
                Team
              </a>
              <a href="#" class="nav__item">
                <i class="ti ti-settings nav__item-icon"></i>
                Settings
              </a>
            </nav>
          </div>
        </div>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
