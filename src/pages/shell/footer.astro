---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Footer" description="Application footer component.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Footer</h1>
      <p class="page-header__description">
        The footer provides supplementary information and links at the bottom of the page.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Footer Examples</h2>
      
      <ExampleSection title="Simple Footer" description="Basic footer with copyright and links.">
        <div class="border rounded-lg overflow-hidden">
          <div class="bg-nav p-4 flex items-center justify-between">
            <span class="text-sm text-muted">© 2024 Company Name. All rights reserved.</span>
            <div class="flex gap-4">
              <a href="#" class="text-sm link link--muted">Privacy</a>
              <a href="#" class="text-sm link link--muted">Terms</a>
              <a href="#" class="text-sm link link--muted">Help</a>
            </div>
          </div>
        </div>
      </ExampleSection>

      <ExampleSection title="Extended Footer" description="Footer with multiple sections.">
        <div class="border rounded-lg overflow-hidden">
          <div class="bg-nav p-6">
            <div class="grid md:grid-cols-4 gap-6 mb-6">
              <div>
                <h4 class="font-semibold text-primary mb-3">Product</h4>
                <ul class="space-y-2">
                  <li><a href="#" class="text-sm link link--muted">Features</a></li>
                  <li><a href="#" class="text-sm link link--muted">Pricing</a></li>
                  <li><a href="#" class="text-sm link link--muted">Documentation</a></li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-primary mb-3">Company</h4>
                <ul class="space-y-2">
                  <li><a href="#" class="text-sm link link--muted">About</a></li>
                  <li><a href="#" class="text-sm link link--muted">Blog</a></li>
                  <li><a href="#" class="text-sm link link--muted">Careers</a></li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-primary mb-3">Support</h4>
                <ul class="space-y-2">
                  <li><a href="#" class="text-sm link link--muted">Help Center</a></li>
                  <li><a href="#" class="text-sm link link--muted">Contact</a></li>
                  <li><a href="#" class="text-sm link link--muted">Status</a></li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-primary mb-3">Legal</h4>
                <ul class="space-y-2">
                  <li><a href="#" class="text-sm link link--muted">Privacy</a></li>
                  <li><a href="#" class="text-sm link link--muted">Terms</a></li>
                  <li><a href="#" class="text-sm link link--muted">Cookies</a></li>
                </ul>
              </div>
            </div>
            <div class="border-t pt-4">
              <span class="text-sm text-muted">© 2024 Company Name. All rights reserved.</span>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
