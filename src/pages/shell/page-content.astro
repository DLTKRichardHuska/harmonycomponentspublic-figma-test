---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ExampleSection from '../../components/ExampleSection.astro';
---

<DocsLayout title="Page Content" description="Main content area structure.">
  <article class="space-y-12">
    <header class="page-header page-header--compact">
      <h1 class="page-header__title page-header__title--sm">Page Content</h1>
      <p class="page-header__description">
        The page content area is the main workspace where primary content and interactions occur.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="section__title">Content Structure</h2>
      
      <ExampleSection title="Page Layout" description="Standard content area with header and body.">
        <div class="border rounded-lg overflow-hidden bg-page">
          <div class="p-6">
            <div class="border-b pb-4 mb-6">
              <h1 class="text-2xl font-bold text-primary mb-2">Page Title</h1>
              <p class="text-secondary">Page description or subtitle goes here.</p>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
              <div class="card">
                <div class="card__body">
                  <h3 class="font-semibold text-primary mb-2">Card 1</h3>
                  <p class="text-sm text-secondary">Content goes here.</p>
                </div>
              </div>
              <div class="card">
                <div class="card__body">
                  <h3 class="font-semibold text-primary mb-2">Card 2</h3>
                  <p class="text-sm text-secondary">Content goes here.</p>
                </div>
              </div>
              <div class="card">
                <div class="card__body">
                  <h3 class="font-semibold text-primary mb-2">Card 3</h3>
                  <p class="text-sm text-secondary">Content goes here.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </ExampleSection>
    </section>
  </article>
</DocsLayout>
