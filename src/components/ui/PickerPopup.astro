---
/**
 * PickerPopup Component
 * 
 * Simple popup container for date/time pickers.
 */
import Icon from './Icon.astro';

export interface Props {
  id: string;
  triggerId?: string;
  class?: string;
  title?: string;
}

const {
  id,
  triggerId,
  class: className = '',
  title,
} = Astro.props;

const classes = ['picker-popup', className].filter(Boolean).join(' ');
---

<div 
  class={classes}
  id={id}
  role="dialog"
  aria-modal="true"
  data-picker-popup
  data-trigger-id={triggerId || ''}
>
  {title && (
    <div class="picker-popup__header">
      <h3 class="picker-popup__title" id={`${id}-title`}>{title}</h3>
      <button 
        type="button" 
        class="picker-popup__close" 
        data-picker-close
        aria-label="Close picker"
      >
        <Icon name="x-mark" size="sm" />
      </button>
    </div>
  )}
  <div class="picker-popup__body">
    <slot />
  </div>
</div>

<script>
  function positionPopup(popup: HTMLElement, trigger: HTMLElement) {
    popup.style.visibility = 'hidden';
    popup.style.display = 'block';
    
    const triggerRect = trigger.getBoundingClientRect();
    const popupRect = popup.getBoundingClientRect();
    const padding = 16;
    
    let top = triggerRect.bottom + 8;
    let left = triggerRect.left;
    
    if (left + popupRect.width > window.innerWidth - padding) {
      left = window.innerWidth - popupRect.width - padding;
    }
    if (left < padding) {
      left = padding;
    }
    
    if (top + popupRect.height > window.innerHeight - padding) {
      top = triggerRect.top - popupRect.height - 8;
      if (top < padding) {
        top = window.innerHeight - popupRect.height - padding;
      }
    }
    
    popup.style.position = 'fixed';
    popup.style.top = `${top}px`;
    popup.style.left = `${left}px`;
    popup.style.visibility = 'visible';
  }
  
  function openPopup(popupId: string) {
    const popup = document.getElementById(popupId) as HTMLElement;
    if (!popup) return;
    
    const triggerId = popup.getAttribute('data-trigger-id');
    const trigger = triggerId ? document.getElementById(triggerId) : null;
    
    if (trigger) {
      positionPopup(popup, trigger);
    }
    
    popup.classList.add('is-open');
  }
  
  function closePopup(popupId: string) {
    const popup = document.getElementById(popupId) as HTMLElement;
    if (!popup) return;
    popup.classList.remove('is-open');
  }
  
  function togglePopup(popupId: string) {
    const popup = document.getElementById(popupId) as HTMLElement;
    if (!popup) return;
    
    if (popup.classList.contains('is-open')) {
      closePopup(popupId);
    } else {
      openPopup(popupId);
    }
  }
  
  // ATTACH TO WINDOW IMMEDIATELY - BEFORE ANY OTHER CODE
  (window as any).openPicker = openPopup;
  (window as any).closePicker = closePopup;
  (window as any).togglePicker = togglePopup;
  
  function isClickInside(target: Element, popup: HTMLElement): boolean {
    if (popup.contains(target)) return true;
    
    const triggerId = popup.getAttribute('data-trigger-id');
    if (triggerId) {
      const trigger = document.getElementById(triggerId);
      if (trigger && (trigger === target || trigger.contains(target))) return true;
      
      const icon = document.querySelector(`[data-date-input-icon="${triggerId}"]`);
      if (icon && (icon === target || icon.contains(target))) return true;
      
      const wrapper = trigger.closest('.date-input-wrapper');
      if (wrapper && (wrapper === target || wrapper.contains(target))) return true;
    }
    
    return false;
  }
  
  function initPopup(popup: HTMLElement) {
    const popupId = popup.id;
    const closeBtn = popup.querySelector('[data-picker-close]');
    
    closeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      closePopup(popupId);
    });
  }
  
  function handleEscape(e: KeyboardEvent) {
    if (e.key === 'Escape') {
      document.querySelectorAll('[data-picker-popup].is-open').forEach((popup) => {
        closePopup((popup as HTMLElement).id);
      });
    }
  }
  
  function handleClickOutside(e: MouseEvent) {
    const target = e.target as Element;
    
    document.querySelectorAll('[data-picker-popup].is-open').forEach((popup) => {
      const popupEl = popup as HTMLElement;
      if (!isClickInside(target, popupEl)) {
        closePopup(popupEl.id);
      }
    });
  }
  
  function initPickerPopups() {
    document.querySelectorAll('[data-picker-popup]:not([data-initialized])').forEach((popup) => {
      popup.setAttribute('data-initialized', 'true');
      initPopup(popup as HTMLElement);
    });
    
    if (!(window as any).pickerHandlersAttached) {
      document.addEventListener('keydown', handleEscape);
      document.addEventListener('click', handleClickOutside);
      (window as any).pickerHandlersAttached = true;
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPickerPopups);
  } else {
    initPickerPopups();
  }
  
  document.addEventListener('astro:page-load', initPickerPopups);
</script>
