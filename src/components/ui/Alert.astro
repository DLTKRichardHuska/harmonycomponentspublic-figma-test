---
/**
 * Alert Component
 * 
 * Notification message with different severity levels.
 */

export interface Props {
  variant?: 'info' | 'success' | 'warning' | 'error';
  title?: string;
  dismissible?: boolean;
  icon?: string;
  class?: string;
}

const {
  variant = 'info',
  title,
  dismissible = false,
  icon,
  class: className = '',
} = Astro.props;

// Default icons for each variant
const defaultIcons: Record<string, string> = {
  info: 'ti-info-circle',
  success: 'ti-circle-check',
  warning: 'ti-alert-triangle',
  error: 'ti-alert-circle',
};

const alertIcon = icon || defaultIcons[variant];

const classes = [
  'alert',
  `alert--${variant}`,
  className,
].filter(Boolean).join(' ');
---

<div class={classes} role="alert">
  <i class={`ti ${alertIcon} alert__icon`}></i>
  <div class="alert__content">
    {title && <div class="alert__title">{title}</div>}
    <div class="alert__message">
      <slot />
    </div>
  </div>
  {dismissible && (
    <button type="button" class="alert__close" aria-label="Dismiss">
      <i class="ti ti-x"></i>
    </button>
  )}
</div>

<script>
  document.querySelectorAll('.alert__close').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.alert')?.remove();
    });
  });
</script>
