---
/**
 * CPRightSidebar Component
 *
 * A CP-specific right navigation sidebar that is docked to the right edge of the screen.
 * Shows only icons when collapsed, expands on hover to show text labels + icon.
 *
 * @prop {Array} sections - Optional custom sections configuration. If not provided, uses default CP sections.
 * @prop {string} class - Additional CSS classes to apply
 */
import Icon from './Icon.astro';

interface NavItem {
  icon: string;
  label: string;
  href?: string;
  active?: boolean;
  isCustom?: boolean;
  customSrc?: string;
  iconSize?: string;
}

interface Section {
  items: NavItem[];
}

interface Props {
  sections?: Section[];
  class?: string;
}

const { sections, class: className = '' } = Astro.props;

// Default CP sections configuration
const cpDefaultSections: Section[] = [
  {
    items: [
      { icon: 'dela-ai', label: 'Dela AI', isCustom: true, customSrc: '/logos/DelaD.svg', iconSize: '36px' },
      { icon: 'bell', label: 'Notifications', iconSize: '24px' },
      { icon: 'arrow-up-tray', label: 'Files', iconSize: '24px' },
    ],
  },
  {
    items: [
      { icon: 'printer', label: 'Print', iconSize: '24px' },
      { icon: 'view-columns', label: 'Layout Options', iconSize: '24px' },
    ],
  },
  {
    items: [
      { icon: 'microphone-slash', label: 'Microphone', iconSize: '24px' },
      { icon: 'signal-slash', label: 'Offline', iconSize: '24px' },
      { icon: 'command-line', label: 'Keyboard Shortcuts', iconSize: '24px' },
      { icon: 'question-mark-circle', label: 'Help', iconSize: '24px' },
    ],
  },
];

// Use provided sections or fall back to defaults
const sidebarSections = sections || cpDefaultSections;
---

<nav class:list={['cp-right-sidebar', className]}>
  {sidebarSections.map((section) => (
    <div class="cp-right-sidebar__section">
      {section.items.map((item) => {
        // Use 'lg' size (24px) for standard icons, special class for 36px custom icons
        const isDelaLogo = item.isCustom && item.iconSize === '36px';
        
        return (
          <a href={item.href || '#'} class:list={['cp-right-sidebar__item', { 'cp-right-sidebar__item--active': item.active }]}>
            <span class="cp-right-sidebar__label">{item.label}</span>
            <span class="cp-right-sidebar__icon">
              {item.isCustom && item.customSrc ? (
                <img src={item.customSrc} alt={item.label} class={isDelaLogo ? 'cp-right-sidebar__dela-logo' : ''} />
              ) : (
                <Icon name={item.icon} size="lg" />
              )}
            </span>
          </a>
        );
      })}
    </div>
  ))}
</nav>


