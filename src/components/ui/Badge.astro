---
/**
 * Badge Component
 * 
 * Small status indicator or label.
 */

export interface Props {
  variant?: 'default' | 'primary' | 'success' | 'warning' | 'error' | 'info';
  icon?: string;
  class?: string;
}

const {
  variant = 'default',
  icon,
  class: className = '',
} = Astro.props;

const classes = [
  'badge',
  `badge--${variant}`,
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  {icon && <i class={`ti ${icon}`}></i>}
  <slot />
</span>
