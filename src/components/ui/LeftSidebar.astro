---
/**
 * LeftSidebar Component
 *
 * A unified left navigation sidebar that supports multiple themes (cp, vp, ppm, maconomy).
 * Shows only icons when collapsed, expands on hover to show icon + text labels.
 * Supports configurable sections and icons per theme.
 *
 * @prop {string} variant - Theme variant: 'cp' | 'vp' | 'ppm' | 'maconomy'
 * @prop {Array} sections - Optional custom sections configuration
 * @prop {string} class - Additional CSS classes to apply
 */
import Icon from './Icon.astro';

interface NavItem {
  icon: string;
  label: string;
  href?: string;
  active?: boolean;
}

interface Section {
  items: NavItem[];
}

interface Props {
  variant?: 'cp' | 'vp' | 'ppm' | 'maconomy';
  sections?: Section[];
  class?: string;
}

const { variant = 'cp', sections, class: className = '' } = Astro.props;

// Default CP configuration (2 sections)
const cpSections: Section[] = [
  {
    items: [
      { icon: 'home', label: 'Welcome screen' },
      { icon: 'squares-2x2', label: 'Dashboard' },
      { icon: 'star', label: 'My menu' },
      { icon: 'clock', label: 'Recent' },
    ],
  },
  {
    items: [
      { icon: 'magnifying-glass', label: 'Search' },
      { icon: 'squares-plus', label: 'Command Center' },
      { icon: 'calculator', label: 'Accounting' },
      { icon: 'chart-bar', label: 'Planning' },
      { icon: 'document-arrow-down', label: 'Capture & contracts' },
      { icon: 'clipboard-document-list', label: 'Projects' },
      { icon: 'cube', label: 'Materials' },
      { icon: 'clock', label: 'Time & expense' },
      { icon: 'users', label: 'People' },
      { icon: 'document-chart-bar', label: 'Reports' },
      { icon: 'cog-6-tooth', label: 'Admin' },
    ],
  },
];

// Default PPM configuration (1 section)
const ppmSections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Default VP configuration (1 section - similar to PPM for now)
const vpSections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Default Maconomy configuration (1 section - similar to PPM for now)
const maconomySections: Section[] = [
  {
    items: [
      { icon: 'rectangle-group', label: 'Command Center', active: true },
      { icon: 'book-open', label: 'Programs' },
      { icon: 'briefcase', label: 'Portfolios' },
      { icon: 'building-office', label: 'Projects' },
      { icon: 'Risk Shield', label: 'Risk' },
      { icon: 'Report', label: 'Reports' },
      { icon: 'calendar-days', label: 'Calendars' },
      { icon: 'document', label: 'Codes' },
      { icon: 'wallet', label: 'Rates' },
      { icon: 'Resource', label: 'Resources' },
      { icon: 'cog-6-tooth', label: 'Settings' },
      { icon: 'plus', label: 'Add Menu' },
    ],
  },
];

// Get sections based on variant or use provided sections
const getSections = (): Section[] => {
  if (sections) return sections;
  
  switch (variant) {
    case 'cp':
      return cpSections;
    case 'ppm':
      return ppmSections;
    case 'vp':
      return vpSections;
    case 'maconomy':
      return maconomySections;
    default:
      return cpSections;
  }
};

const sidebarSections = getSections();

// If custom sections are provided, only render those
// Otherwise, render all variants and use CSS to show/hide based on theme
const shouldRenderAllVariants = !sections;
---

<nav class:list={['left-sidebar', `left-sidebar--${variant}`, className]} data-variant={variant}>
  {shouldRenderAllVariants ? (
    <>
      <!-- CP Variant (2 sections) -->
      <div class="left-sidebar__variant left-sidebar__variant--cp">
        {cpSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => (
              <a 
                href={item.href || '#'} 
                class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
              >
                <span class="left-sidebar__icon">
                  <Icon name={item.icon} />
                </span>
                <span class="left-sidebar__label">{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </div>

      <!-- VP Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--vp">
        {vpSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => (
              <a 
                href={item.href || '#'} 
                class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
              >
                <span class="left-sidebar__icon">
                  <Icon name={item.icon} />
                </span>
                <span class="left-sidebar__label">{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </div>

      <!-- PPM Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--ppm">
        {ppmSections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => (
              <a 
                href={item.href || '#'} 
                class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
              >
                <span class="left-sidebar__icon">
                  <Icon name={item.icon} />
                </span>
                <span class="left-sidebar__label">{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </div>

      <!-- Maconomy Variant (1 section) -->
      <div class="left-sidebar__variant left-sidebar__variant--maconomy">
        {maconomySections.map((section, sectionIndex) => (
          <div class="left-sidebar__section">
            {section.items.map((item) => (
              <a 
                href={item.href || '#'} 
                class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
              >
                <span class="left-sidebar__icon">
                  <Icon name={item.icon} />
                </span>
                <span class="left-sidebar__label">{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </div>
    </>
  ) : (
    // Custom sections provided - render only those
    sidebarSections.map((section, sectionIndex) => (
      <div class="left-sidebar__section">
        {section.items.map((item) => (
          <a 
            href={item.href || '#'} 
            class:list={['left-sidebar__item', { 'left-sidebar__item--active': item.active }]}
          >
            <span class="left-sidebar__icon">
              <Icon name={item.icon} />
            </span>
            <span class="left-sidebar__label">{item.label}</span>
          </a>
        ))}
      </div>
    ))
  )}
</nav>

<style>
  /* Hide all variants by default */
  .left-sidebar__variant {
    display: none;
  }

  /* Show CP variant when CP theme is active */
  html.theme-cp .left-sidebar__variant--cp {
    display: contents;
  }

  /* Show VP variant when VP theme is active */
  html.theme-vp .left-sidebar__variant--vp {
    display: contents;
  }

  /* Show PPM variant when PPM theme is active */
  html.theme-ppm .left-sidebar__variant--ppm {
    display: contents;
  }

  /* Show Maconomy variant when Maconomy theme is active */
  html.theme-maconomy .left-sidebar__variant--maconomy {
    display: contents;
  }
</style>
