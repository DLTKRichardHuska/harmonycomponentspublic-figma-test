---
import Icon from './Icon.astro';
import Avatar from './Avatar.astro';

interface Props {
  productName?: string;
  logoSrc?: string;
  companyName?: string;
  showCompanyPicker?: boolean;
  companyColor?: string;
  class?: string;
}

const {
  productName = 'Harmony',
  logoSrc = '/logos/CPVPLogo.svg',
  companyName = 'Company name',
  showCompanyPicker = true,
  companyColor,
  class: className = ''
} = Astro.props;
---

<header class={`header ${className}`}>
  <!-- Left: Brand -->
  <div class="header__brand">
    <a href="/" class="header__brand-link">
      <img src={logoSrc} alt="Logo" class="header__logo" />
      <span class="header__title">{productName}</span>
    </a>
  </div>

  <!-- Right: Company dropdown + Avatar -->
  <div class="header__actions">
    {showCompanyPicker && (
      <>
        <!-- Company Picker -->
        <div class="company-picker">
          <button class="company-picker__btn" data-company-picker-btn>
            <span 
              class="company-picker__indicator"
              data-company-indicator
              style={companyColor ? `background-color: ${companyColor}` : undefined}
            ></span>
            <span class="company-picker__name" data-company-name>{companyName}</span>
            <Icon name="chevron-down" size="sm" class="company-picker__chevron" />
          </button>
          <div class="company-picker__menu" data-company-picker-menu>
            <button class="company-picker__option company-picker__option--selected" data-company-option data-company-id="acme-corp">
              <span class="company-picker__option-indicator company-picker__option-indicator--acme"></span>
              <span class="company-picker__option-name">Acme Corporation</span>
            </button>
            <button class="company-picker__option" data-company-option data-company-id="ocean-industries">
              <span class="company-picker__option-indicator company-picker__option-indicator--ocean"></span>
              <span class="company-picker__option-name">Ocean Industries</span>
            </button>
            <button class="company-picker__option" data-company-option data-company-id="violet-systems">
              <span class="company-picker__option-indicator company-picker__option-indicator--violet"></span>
              <span class="company-picker__option-name">Violet Systems</span>
            </button>
            <button class="company-picker__option" data-company-option data-company-id="azure-dynamics">
              <span class="company-picker__option-indicator company-picker__option-indicator--azure"></span>
              <span class="company-picker__option-name">Azure Dynamics</span>
            </button>
            <button class="company-picker__option" data-company-option data-company-id="sunset-corporation">
              <span class="company-picker__option-indicator company-picker__option-indicator--sunset"></span>
              <span class="company-picker__option-name">Sunset Corporation</span>
            </button>
          </div>
        </div>

        <div class="divider"></div>
      </>
    )}

    <!-- User Avatar -->
    <Avatar size="sm" />
  </div>

  <!-- Gradient Border -->
  <div 
    class="header__gradient"
    data-header-gradient
    style={companyColor ? `background: linear-gradient(to right, ${companyColor}05, ${companyColor} 50%, ${companyColor}05)` : undefined}
  ></div>
</header>

<script>
  let outsideClickListenerAdded = false;
  
  // Helper: Convert RGB/RGBA to hex
  function rgbToHex(rgb: string): string {
    if (!rgb || rgb.startsWith('#')) return rgb;
    
    const values = rgb.match(/\d+/g);
    if (!values || values.length < 3) return rgb;
    
    const r = parseInt(values[0]).toString(16).padStart(2, '0');
    const g = parseInt(values[1]).toString(16).padStart(2, '0');
    const b = parseInt(values[2]).toString(16).padStart(2, '0');
    return `#${r}${g}${b}`.toUpperCase();
  }
  
  function initCompanyPickers() {
    document.querySelectorAll('[data-company-picker-btn]').forEach((pickerBtn) => {
      // Skip if already initialized
      if (pickerBtn.hasAttribute('data-init')) return;
      pickerBtn.setAttribute('data-init', 'true');
      
      const pickerMenu = pickerBtn.parentElement?.querySelector('[data-company-picker-menu]');
      if (!pickerMenu) return;
      
      // Find the header element that contains this picker
      const header = pickerBtn.closest('.header');
      if (!header) return;
      
      const companyIndicator = pickerBtn.querySelector('[data-company-indicator]') as HTMLElement;
      const companyName = pickerBtn.querySelector('[data-company-name]') as HTMLElement;
      const headerGradient = header.querySelector('[data-header-gradient]') as HTMLElement;
      
      // Toggle dropdown on button click
      pickerBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        pickerMenu.classList.toggle('company-picker__menu--open');
      });
      
      // Handle company selection
      pickerMenu.querySelectorAll('[data-company-option]').forEach((option) => {
        option.addEventListener('click', (e) => {
          e.stopPropagation();
          const companyId = option.getAttribute('data-company-id');
          const optionName = option.querySelector('.company-picker__option-name')?.textContent;
          const indicator = option.querySelector('.company-picker__option-indicator') as HTMLElement;
          
          // Update selected state
          pickerMenu.querySelectorAll('[data-company-option]').forEach(opt => {
            opt.classList.remove('company-picker__option--selected');
          });
          option.classList.add('company-picker__option--selected');
          
          // Update display
          if (companyName && optionName) {
            companyName.textContent = optionName;
          }
          
          // Get color from CSS variable via computed style (reads from token)
          if (companyIndicator && indicator) {
            const computedColor = window.getComputedStyle(indicator).backgroundColor;
            companyIndicator.style.backgroundColor = computedColor;
            
            // Update gradient border - convert RGB to hex if needed
            if (headerGradient && computedColor) {
              const hexColor = rgbToHex(computedColor);
              headerGradient.style.background = `linear-gradient(to right, ${hexColor}05, ${hexColor} 50%, ${hexColor}05)`;
            }
          }
          
          // Close menu
          pickerMenu.classList.remove('company-picker__menu--open');
        });
      });
    });
    
    // Close dropdown when clicking outside (only one listener needed)
    if (!outsideClickListenerAdded) {
      outsideClickListenerAdded = true;
      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        document.querySelectorAll('[data-company-picker-menu]').forEach((menu) => {
          const btn = menu.parentElement?.querySelector('[data-company-picker-btn]');
          if (btn && !btn.contains(target) && !menu.contains(target)) {
            menu.classList.remove('company-picker__menu--open');
          }
        });
      });
    }
  }
  
  // Initialize on page load
  initCompanyPickers();
  document.addEventListener('astro:page-load', initCompanyPickers);
</script>
