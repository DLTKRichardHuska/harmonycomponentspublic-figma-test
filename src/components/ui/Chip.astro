---
/**
 * Chip Component
 * 
 * Compact element for tags, filters, or selections.
 */

export interface Props {
  selected?: boolean;
  removable?: boolean;
  icon?: string;
  class?: string;
}

const {
  selected = false,
  removable = false,
  icon,
  class: className = '',
} = Astro.props;

const classes = [
  'chip',
  selected && 'chip--selected',
  className,
].filter(Boolean).join(' ');
---

<span class={classes}>
  {icon && <i class={`ti ${icon}`}></i>}
  <slot />
  {removable && (
    <button type="button" class="chip__remove" aria-label="Remove">
      <i class="ti ti-x"></i>
    </button>
  )}
</span>
