---
/**
 * Tooltip Component
 * 
 * Informational popup on hover.
 */

export interface Props {
  text: string;
  position?: 'top' | 'bottom';
  class?: string;
}

const {
  text,
  position = 'top',
  class: className = '',
} = Astro.props;

const contentClasses = [
  'tooltip__content',
  position === 'bottom' && 'tooltip__content--bottom',
].filter(Boolean).join(' ');

const classes = ['tooltip', className].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
  <span class={contentClasses}>{text}</span>
</span>
