---
/**
 * Card Component
 * 
 * Container for grouped content with optional header and footer.
 */

export interface Props {
  elevated?: boolean;
  interactive?: boolean;
  class?: string;
}

const {
  elevated = false,
  interactive = false,
  class: className = '',
} = Astro.props;

const classes = [
  'card',
  elevated && 'card--elevated',
  interactive && 'card--interactive',
  className,
].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
