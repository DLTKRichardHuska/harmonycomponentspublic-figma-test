---
/**
 * Link Component
 * 
 * Styled anchor element.
 */

export interface Props {
  href: string;
  external?: boolean;
  muted?: boolean;
  class?: string;
  [key: string]: any;
}

const {
  href,
  external = false,
  muted = false,
  class: className = '',
  ...rest
} = Astro.props;

const classes = [
  'link',
  muted && 'link--muted',
  className,
].filter(Boolean).join(' ');
---

<a 
  href={href} 
  class={classes}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  {...rest}
>
  <slot />
  {external && <i class="ti ti-external-link" style="margin-left: 4px; font-size: 0.875em;"></i>}
</a>
