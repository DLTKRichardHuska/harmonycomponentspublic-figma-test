---
/**
 * ComponentDoc Component
 * 
 * Documentation template for component pages.
 */

interface Props {
  name: string;
  description: string;
  status?: 'stable' | 'beta' | 'deprecated';
}

const { name, description, status = 'stable' } = Astro.props;
---

<article class="space-y-12">
  <!-- Header -->
  <header class="page-header page-header--compact">
    <div class="flex items-center gap-3 mb-4">
      <h1 class="page-header__title page-header__title--sm">{name}</h1>
      <span class={`badge badge--${status === 'stable' ? 'success' : status === 'beta' ? 'warning' : 'error'}`}>
        {status}
      </span>
    </div>
    <p class="page-header__description">{description}</p>
  </header>

  <!-- Quick Links -->
  <nav class="article-nav">
    <a href="#examples" class="article-nav__link">
      <i class="ti ti-eye"></i> Examples
    </a>
    <a href="#props" class="article-nav__link">
      <i class="ti ti-list"></i> Props
    </a>
    <a href="#usage" class="article-nav__link">
      <i class="ti ti-book"></i> Usage
    </a>
    <a href="#accessibility" class="article-nav__link">
      <i class="ti ti-accessible"></i> Accessibility
    </a>
  </nav>

  <!-- Content slots -->
  <slot />
</article>
