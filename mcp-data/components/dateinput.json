  "_variantMetadata": {
    "availableVariants": [
      "date",
      "time",
      "datetime-local",
      "month",
      "week",
      "inline",
      "stacked"
    ]
  },
  "interactivity": {
    "hasInteractivity": true,
    "initialization": {
      "function": "initDateInputs",
      "triggers": [
        "DOMContentLoaded (implicit via immediate call)",
        "astro:page-load"
      ],
      "preventDoubleInit": true,
      "preventDoubleInitMethod": "data-init attribute on input element",
      "description": "Initializes all date input components on the page. Sets up click handlers for input and icon to toggle picker popup, and listens for custom events from picker components to update values."
    },
    "state": {
      "popupOpen": {
        "type": "boolean",
        "managedBy": "CSS class on popup element",
        "class": "is-open",
        "description": "Controls visibility of picker popup. When present on [data-picker-popup], popup is visible. When absent, popup is hidden.",
        "setBy": "Input/icon click (if popup was closed)",
        "clearedBy": "Input/icon click (if popup was open), picker selection, outside click (handled by PickerPopup)"
      },
      "displayValue": {
        "type": "string",
        "managedBy": "value attribute on visible input element",
        "element": "input[data-date-input]",
        "description": "Formatted display value shown to user (readonly input)",
        "format": "Formatted based on input type and locale (e.g., 'Jan 15, 2024' for date)",
        "syncsWith": "hiddenInputValue via formatDisplayValue function"
      },
      "hiddenInputValue": {
        "type": "string",
        "managedBy": "value attribute on hidden input element",
        "element": "input[data-date-input-value]",
        "description": "Raw value for form submission (ISO format: YYYY-MM-DD, HH:mm, etc.)",
        "syncsWith": "displayValue - updated when picker emits selection event"
      }
    },
    "eventHandlers": [
      {
        "element": "[data-date-input]",
        "event": "click",
        "handler": "togglePicker",
        "description": "Toggles picker popup open/closed when clicking on input field",
        "condition": "Input is not disabled",
        "preventDefault": true,
        "stopPropagation": true,
        "actions": [
          "Check if input is disabled, return early if so",
          "Stop event propagation (prevents race with outside click handler)",
          "Prevent default behavior",
          "Check if popup is currently open (has 'is-open' class)",
          "If open: Remove 'is-open' class from popup",
          "If closed: Close all other open pickers (querySelectorAll('[data-picker-popup].is-open')), then add 'is-open' class to this popup"
        ],
        "note": "CRITICAL: stopPropagation prevents race condition with PickerPopup's outside click handler"
      },
      {
        "element": "[data-date-input-icon]",
        "event": "click",
        "handler": "togglePicker",
        "description": "Toggles picker popup open/closed when clicking on icon button",
        "condition": "Icon button is not disabled",
        "preventDefault": true,
        "stopPropagation": true,
        "actions": [
          "Same as input click handler - shares togglePicker function"
        ],
        "note": "Icon button and input field both trigger same toggle function"
      },
      {
        "element": "[data-date-picker], [data-time-picker], [data-datetime-picker], [data-month-picker], [data-week-picker]",
        "event": "date-select, time-select, datetime-select, month-select, week-select",
        "handler": "handlePickerSelection",
        "description": "Handles selection events from picker components and updates input values",
        "customEvent": true,
        "events": [
          {
            "name": "date-select",
            "detail": { "date": "string (YYYY-MM-DD format)" },
            "action": "Update hiddenInput.value and inputEl.value, close popup"
          },
          {
            "name": "time-select",
            "detail": { "time": "string (HH:mm format)" },
            "action": "Update hiddenInput.value and inputEl.value, close popup"
          },
          {
            "name": "datetime-select",
            "detail": { "datetime": "string (YYYY-MM-DDTHH:mm format)" },
            "action": "Update hiddenInput.value and inputEl.value, close popup"
          },
          {
            "name": "month-select",
            "detail": { "value": "string (YYYY-MM format)" },
            "action": "Update hiddenInput.value and inputEl.value, close popup"
          },
          {
            "name": "week-select",
            "detail": { "value": "string (YYYY-Www format)" },
            "action": "Update hiddenInput.value and inputEl.value, close popup"
          }
        ],
        "actions": [
          "Extract value from event.detail (date/time/datetime/month/week property)",
          "Update hidden input value (input[data-date-input-value])",
          "Format value using formatDisplayValue() function with inputType and locale",
          "Update visible input value (input[data-date-input])",
          "Remove 'is-open' class from popup to close it"
        ],
        "note": "Different event types based on input type - component listens for appropriate event"
      }
    ],
    "keyboardSupport": {
      "native": {
        "description": "Input is readonly, but supports basic keyboard navigation",
        "Tab": "Navigates to next focusable element",
        "Shift+Tab": "Navigates to previous focusable element",
        "Enter": "No action (input is readonly)",
        "Space": "No action (input is readonly)"
      },
      "custom": {
        "description": "No custom keyboard navigation - picker components handle their own keyboard support"
      }
    },
    "dataAttributes": {
      "data-date-input": {
        "purpose": "Identifies date input element for initialization",
        "required": true,
        "location": "On input[type='text'] element",
        "usedBy": "initDateInputs function to find all date input instances"
      },
      "data-input-type": {
        "purpose": "Stores the input type (date, time, datetime-local, month, week)",
