        "usedBy": "formatDisplayValue function to format value correctly",
        "setBy": "type prop"
      },
      "data-date-input-value": {
        "purpose": "Identifies hidden input element storing raw form value",
        "location": "On input[type='hidden'] element",
        "usedBy": "Selection handlers to update form submission value"
      },
      "data-date-input-icon": {
        "purpose": "Identifies icon button element for toggle functionality",
        "location": "On icon button element",
        "format": "data-date-input-icon=\"{inputId}\"",
        "usedBy": "Toggle handler to find icon button for specific input"
      },
      "data-trigger-id": {
        "purpose": "Stores input ID on popup for coordination",
        "location": "On [data-picker-popup] element",
        "setBy": "initDateInputs function",
        "usedBy": "PickerPopup component for positioning and outside click detection"
      },
      "data-init": {
        "purpose": "Prevents double initialization",
        "values": ["true"],
        "setBy": "initDateInputs function after first initialization",
        "checkedBy": "initDateInputs checks hasAttribute('data-init') before initializing"
      }
    },
    "globalFunctions": {},
    "customEvents": [],
    "dependencies": {
      "internal": [
        "initDateInputs function",
        "formatDisplayValue function (duplicated in script tag)",
        "querySelector/querySelectorAll for element selection",
        "getElementById for popup lookup"
      ],
      "external": [
        "PickerPopup component (must exist in DOM with id={inputId}-popup)",
        "DatePicker, TimePicker, DateTimePicker, MonthPicker, or WeekPicker component (based on type prop)"
      ]
    },
    "coordination": {
      "withPickerPopup": {
        "popupId": "{inputId}-popup (where inputId is date input id)",
        "triggerId": "Set via data-trigger-id attribute on popup",
        "openState": "Controlled by 'is-open' class on popup",
        "positioning": "Handled by PickerPopup component CSS",
        "outsideClick": "Handled by PickerPopup component"
      },
      "withPickerComponents": {
        "dateSelect": "Listens for 'date-select' event from DatePicker",
        "timeSelect": "Listens for 'time-select' event from TimePicker",
        "datetimeSelect": "Listens for 'datetime-select' event from DateTimePicker",
        "monthSelect": "Listens for 'month-select' event from MonthPicker",
        "weekSelect": "Listens for 'week-select' event from WeekPicker",
        "pickerId": "{inputId}-picker (where inputId is date input id)",
        "description": "Component dynamically renders appropriate picker based on type prop"
      },
      "singleOpenEnforcement": {
        "description": "Only one picker popup can be open at a time across all date inputs",
        "method": "Before opening a popup, close all other open pickers",
        "selector": "[data-picker-popup].is-open",
        "action": "Remove 'is-open' class from all except current popup"
      },
      "valueFormatting": {
        "date": "Formats as locale date string (e.g., 'Jan 15, 2024')",
        "time": "Formats as HH:mm (e.g., '14:30')",
        "datetime-local": "Formats as date + time (e.g., 'Jan 15, 2024 14:30')",
        "month": "Formats as month name + year (e.g., 'January 2024')",
        "week": "Formats as 'YYYY, Week N' (e.g., '2024, Week 3')",
