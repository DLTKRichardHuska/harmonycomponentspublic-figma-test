  "cssClassStyles": {
    ".cp-left-sidebar": {
      "position": "fixed",
      "left": "0",
      "top": "50%",
      "transform": "translateY(-50%)",
      "z-index": "200",
      "display": "flex",
      "flex-direction": "column",
      "gap": "16px",
      "width": "52px",
      "transition": "width 200ms ease",
      "overflow": "visible"
    },
    ".cp-left-sidebar:hover": {
      "width": "220px"
    },
    ".cp-left-sidebar__section": {
      "background-color": "#FCFDFF",
      "border": "1px solid #ffffff",
      "border-left": "none",
      "border-radius": "0 12px 12px 0",
      "box-shadow": "0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)",
      "padding": "8px 8px",
      "display": "flex",
      "flex-direction": "column",
      "gap": "16px",
      "overflow": "visible"
    },
    ".shell-layout[data-cp-variant=\"true\"] .cp-left-sidebar__section": {
      "gap": "6px"
    },
    ".cp-left-sidebar__item": {
      "display": "flex",
      "align-items": "center",
      "gap": "8px",
      "padding": "6px",
      "border-radius": "8px",
      "text-decoration": "none",
      "color": "#373f4e",
      "white-space": "nowrap",
      "transition": "background-color 150ms ease"
    },
    ".cp-left-sidebar__item:hover": {
      "background-color": "rgba(55, 63, 78, 0.08)",
      "text-decoration": "none"
    },
    ".cp-left-sidebar__item--active": {
      "background-color": "#4C92D9",
      "color": "#FFFFFF"
    },
    ".cp-left-sidebar__item--active:hover": {
      "background-color": "#3D7BC4",
      "color": "#FFFFFF"
    },
    ".cp-left-sidebar__icon": {
      "flex-shrink": "0",
      "width": "24px",
      "height": "24px",
      "display": "flex",
      "align-items": "center",
      "justify-content": "center"
    },
    ".cp-left-sidebar__icon svg": {
      "width": "24px",
      "height": "24px"
    },
    ".cp-left-sidebar__label": {
      "font-family": "'Figtree', sans-serif",
      "font-size": "0.875rem",
      "font-weight": "400",
      "line-height": "1.5",
      "letter-spacing": "normal",
      "opacity": "0",
      "visibility": "hidden",
      "transition": "opacity 200ms ease, visibility 200ms ease"
    },
    ".cp-left-sidebar:hover .cp-left-sidebar__label": {
      "opacity": "1",
      "visibility": "visible"
    },
    "html.theme-cp.dark .cp-left-sidebar__section": {
      "background-color": "#333d47",
      "border-color": "#4a5568"
    },
    "html.theme-cp.dark .cp-left-sidebar__item": {
      "color": "#e9ecef"
    },
    "html.theme-cp.dark .cp-left-sidebar__item:hover": {
      "background-color": "rgba(255, 255, 255, 0.08)"
    },
    "html.theme-cp.dark .cp-left-sidebar__item--active": {
      "background-color": "#59ACFF",
      "color": "#1F252E"
    },
    "html.theme-cp.dark .cp-left-sidebar__item--active:hover": {
      "background-color": "#7BB8FF",
      "color": "#1F252E"
    }
  }
