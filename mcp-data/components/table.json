      "border-spacing": "0",
      "font-family": "var(--font-sans)",
      "font-size": "var(--text-xs)",
      "overflow": "hidden",
      "border-radius": "var(--radius-12)",
      "min-width": "var(--table-min-width)"
    },
    ".table--header-gray thead th": {
      "background-color": "var(--table-header-gray-bg)"
    },
    ".table--header-white thead th": {
      "background-color": "var(--surface-bg)"
    },
    ".table--header-none thead th": {
      "background-color": "transparent"
    },
    ".table--striped tbody tr:nth-child(even)": {
      "background-color": "var(--card-bg)"
    },
    ".table--striped tbody tr:nth-child(odd)": {
      "background-color": "var(--surface-bg)"
    },
    ".table--striped tbody tr.table-row--selected,\n.table--striped tbody tr:has(.checkbox__input:checked)": {
      "background-color": "var(--table-row-selected-bg)"
    },
    ".table--striped tbody tr:hover:not(.table-row--selected):not(:has(.checkbox__input:checked))": {
      "background-color": "var(--table-row-hover-bg)"
    },
    ".table--striped tbody tr.table-row--selected:hover,\n.table--striped tbody tr:has(.checkbox__input:checked):hover": {
      "background-color": "var(--table-row-selected-hover-bg)"
    },
    ".table-wrapper": {
      "border-radius": "var(--radius-12)",
      "overflow": "hidden"
    },
    ".table__title-bar": {
      "padding": "var(--space-4) var(--space-4) var(--space-3)",
      "border-top": "1px solid var(--border-color)",
      "border-left": "1px solid var(--border-color)",
      "border-right": "1px solid var(--border-color)",
      "border-bottom": "1px solid var(--border-color)",
      "background-color": "var(--surface-bg)",
      "border-top-left-radius": "var(--radius-12)",
      "border-top-right-radius": "var(--radius-12)",
      "font-family": "var(--font-display)",
      "font-size": "var(--text-13)"
    },
    ".table__title-bar-content": {
      "display": "flex",
      "align-items": "center",
      "justify-content": "space-between"
    },
    ".table__title-bar-icons": {
      "display": "flex",
      "align-items": "center",
      "gap": "var(--space-2)"
    },
    ".table__title-bar-icon": {
      "display": "flex",
      "align-items": "center",
      "justify-content": "center",
      "width": "var(--space-6)",
      "height": "var(--space-6)",
      "padding": "0",
      "border": "none",
      "background": "transparent",
      "color": "var(--text-secondary)",
      "cursor": "pointer",
      "border-radius": "var(--radius-04)",
      "transition": "background-color var(--transition-fast), color var(--transition-fast)"
    },
    ".table__title-bar-icon:hover": {
      "background-color": "var(--elevated-bg)",
      "color": "var(--text-primary)"
    },
    ".table__title-bar-icon:focus": {
      "outline": "2px solid var(--theme-primary)",
      "outline-offset": "var(--space-0-5)"
    },
    ".table__action-bar": {
      "display": "flex",
      "align-items": "center",
      "justify-content": "flex-start",
      "padding": "var(--space-3) var(--space-4) var(--space-3) var(--space-1)",
      "border-left": "1px solid var(--border-color)",
      "border-right": "1px solid var(--border-color)",
      "border-bottom": "1px solid var(--border-color)",
      "background-color": "var(--table-header-gray-bg)",
      "gap": "var(--space-4)"
    },
    ".table-wrapper:has(.table__action-bar):not(:has(.table__title-bar)) .table__action-bar": {
      "border-top": "1px solid var(--border-color)",
      "border-top-left-radius": "var(--radius-12)",
      "border-top-right-radius": "var(--radius-12)"
    },
    ".table__action-items": {
      "display": "flex",
      "align-items": "center",
      "gap": "var(--space-2)",
      "flex-wrap": "wrap"
    },
    ".table__action-divider": {
      "color": "var(--text-secondary)",
      "font-size": "var(--text-sm)",
      "padding": "0 var(--space-1)",
      "flex-shrink": "0"
    },
    ".table-wrapper:has(.table__title-bar) .table": {
      "border-top-left-radius": "0",
      "border-top-right-radius": "0"
    },
    ".table-wrapper:has(.table__title-bar) .table thead tr:first-child th:first-child": {
      "border-top-left-radius": "0",
      "border-top": "none"
    },
    ".table-wrapper:has(.table__title-bar) .table thead tr:first-child th:last-child": {
      "border-top-right-radius": "0",
      "border-top": "none"
    },
    ".table-wrapper:has(.table__title-bar) .table thead tr:first-child th": {
      "border-top": "none"
    },
    ".table-wrapper:has(.table__action-bar):not(:has(.table__title-bar)) .table": {
      "border-top-left-radius": "0",
      "border-top-right-radius": "0"
    },
    ".table-wrapper:has(.table__action-bar):not(:has(.table__title-bar)) .table thead tr:first-child th:first-child": {
      "border-top-left-radius": "0",
      "border-top": "none"
    },
    ".table-wrapper:has(.table__action-bar):not(:has(.table__title-bar)) .table thead tr:first-child th:last-child": {
      "border-top-right-radius": "0",
      "border-top": "none"
    },
    ".table-wrapper:has(.table__action-bar):not(:has(.table__title-bar)) .table thead tr:first-child th": {
      "border-top": "none"
    }
  },
