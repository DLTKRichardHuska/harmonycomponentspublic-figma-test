{
  "name": "TimePicker",
  "type": "component",
  "filePath": "src/components/ui/TimePicker.astro",
  "description": "TimePicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "format": {
      "type": "'12' | '24'",
      "optional": true,
      "default": "'24'"
    },
    "step": {
      "type": "number",
      "optional": true,
      "default": "1"
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "layout": { "display": "flex", "flexDirection": "column", "alignItems": "stretch", "justifyContent": "flex-start", "gap": "8px" },
      "spacing": { "paddingTop": "8px", "paddingRight": "8px", "paddingBottom": "8px", "paddingLeft": "8px" },
      "dimensions": { "width": "auto", "height": "auto", "minWidth": "auto", "maxWidth": "none" },
      "typography": { "fontFamily": "'Figtree', sans-serif", "fontSize": "0.875rem", "fontWeight": "400", "lineHeight": "1.5" },
      "borders": { "width": "1px", "style": "solid", "radius": "8px", "border": "1px solid #BFC6D4" },
      "states": {
        "default": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "hover": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "active": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "focus": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "disabled": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" }
      }
    }
  },
  "guidance": {
    "patterns": {},
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "change",
        "description": "Triggered when time is selected"
      }
    ],
    "state": [
      {
        "name": "value",
        "type": "string",
        "description": "Selected time"
      }
    ]
  },
  "examples": [
    {
      "name": "Time selection",
      "description": "Pick time",
      "snippet": "<TimePicker value={...} />"
    }
  ]
}