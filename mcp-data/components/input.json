  "elevations": {
    "focusRings": {
      "primary": "0 0 0 3px var(--theme-primary-light), 0 0 0 4px var(--card-bg)",
      "error": "0 0 0 1px var(--border-color), 0 0 0 3px var(--color-error-focus)",
      "resolved": {
        "cp": {
          "light": {
            "primary": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
            "error": "0 0 0 1px #BFC6D4, 0 0 0 3px rgba(216, 49, 72, 0.32)"
          },
          "dark": {
            "primary": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #37424D",
            "error": "0 0 0 1px #5F6871, 0 0 0 3px rgba(244, 98, 134, 0.32)"
          }
        },
        "vp": {
          "light": {
            "primary": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
            "error": "0 0 0 1px #BFC6D4, 0 0 0 3px rgba(216, 49, 72, 0.32)"
          },
          "dark": {
            "primary": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #1F2124",
            "error": "0 0 0 1px #2A2D32, 0 0 0 3px rgba(244, 98, 134, 0.32)"
          }
        },
        "ppm": {
          "light": {
            "primary": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
            "error": "0 0 0 1px #BFC6D4, 0 0 0 3px rgba(216, 49, 72, 0.32)"
          },
          "dark": {
            "primary": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #1F2124",
            "error": "0 0 0 1px #2A2D32, 0 0 0 3px rgba(244, 98, 134, 0.32)"
          }
        },
        "maconomy": {
          "light": {
            "primary": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
            "error": "0 0 0 1px #BFC6D4, 0 0 0 3px rgba(216, 49, 72, 0.32)"
          },
          "dark": {
            "primary": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #1F2124",
            "error": "0 0 0 1px #2A2D32, 0 0 0 3px rgba(244, 98, 134, 0.32)"
          }
        }
      }
    },
    "cssVars": {
      "focusRingPrimary": "--focus-ring-primary",
      "focusRingError": "--focus-ring-error"
    }
  },
  "states": {
    "default": {
      "backgroundColor": "var(--input-bg)",
      "color": "var(--text-primary)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "8px",
      "cursor": "text"
    },
    "hover": {
      "backgroundColor": "var(--input-bg)"
    },
    "focus": {
      "outline": "none",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--focus-ring-primary)"
    },
    "disabled": {
      "backgroundColor": "var(--input-disabled-bg)",
      "color": "var(--text-muted)",
      "cursor": "not-allowed",
      "opacity": "1"
    },
    "error": {
      "borderColor": "var(--color-error)",
      "borderWidth": "2px"
    },
    "errorFocus": {
      "outline": "none",
      "borderColor": "var(--color-error)",
      "boxShadow": "var(--focus-ring-error)"
    }
  },
  "cssClassStyles": {
    ".input": {
      "width": "100%",
      "height": "var(--space-10)",
      "padding": "0 var(--space-4)",
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-base)",
      "color": "var(--text-primary)",
      "backgroundColor": "var(--input-bg)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "var(--radius-lg)",
      "transition": "all var(--transition-fast)",
      "boxSizing": "border-box"
    },
    ".input::placeholder": {
      "color": "var(--text-muted)"
    },
    ".input:focus": {
      "outline": "none",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".input:disabled": {
      "backgroundColor": "var(--input-disabled-bg)",
      "color": "var(--text-muted)",
      "cursor": "not-allowed"
    },
    ".input--error": {
      "borderColor": "var(--color-error)",
      "borderWidth": "var(--border-width-standard)"
    },
    ".input--error:focus": {
      "boxShadow": "var(--focus-ring-error)"
    },
    ".input--with-icon": {
      "paddingLeft": "var(--space-10)"
    },
    ".input-wrapper": {
      "position": "relative"
    },
    ".input-wrapper__icon": {
      "position": "absolute",
      "left": "var(--space-4)",
      "top": "50%",
      "transform": "translateY(-50%)",
      "color": "var(--text-muted)",
      "pointerEvents": "none",
      "zIndex": "var(--z-10)"
    },
    ".input-wrapper__error": {
      "marginTop": "var(--space-1)",
      "fontSize": "var(--text-sm)",
      "color": "var(--color-error)"
    },
    ".input-form-wrapper": {
      "display": "flex",
      "flexDirection": "column"
    },
    ".input-form-wrapper--inline": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "gap": "var(--space-1)"
    },
    ".input-form-wrapper--stacked": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--space-1-5)"
    },
    ".input-form-wrapper__label": {
      "marginBottom": "0",
      "whiteSpace": "nowrap"
    },
    ".theme-cp .input": {
      "height": "var(--input-height-cp)",
      "padding": "0 var(--space-2)",
      "fontSize": "var(--text-xs)",
      "lineHeight": "var(--input-height-cp)"
    },
    ".theme-cp .input--with-icon": {
      "paddingLeft": "var(--space-8)"
    },
    ".theme-cp .input-wrapper__icon": {
      "left": "var(--space-2)",
      "top": "calc(50% + 0.5px)"
    },
    "@media (max-width: var(--breakpoint-md))": {
      ".input": {
        "width": "100%",
        "minHeight": "44px",
        "padding": "0 var(--space-3)",
        "fontSize": "16px"
      }
    }
  }
}
