        "actions": [
          "Get click target and event path using e.composedPath()",
          "For each open popup:",
          "  Get trigger ID from data-trigger-id attribute",
          "  Find trigger element and its .date-input-wrapper parent",
          "  Check if click is outside both popup AND wrapper (using path.includes())",
          "  If outside: Remove 'is-open' class from popup"
        ],
        "note": "CRITICAL: Uses composedPath() for reliable outside detection, checks both popup and wrapper"
      },
      {
