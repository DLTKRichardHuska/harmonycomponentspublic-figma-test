{
  "name": "Step",
  "type": "component",
  "filePath": "src/components/ui/Step.astro",
  "description": "Step Component",
  "props": {
    "completed": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "error": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "warning": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "success": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "icon": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "layout": { "display": "flex", "flexDirection": "row", "alignItems": "center", "justifyContent": "flex-start", "gap": "8px" },
      "spacing": { "paddingTop": "0", "paddingRight": "0", "paddingBottom": "0", "paddingLeft": "0" },
      "dimensions": { "width": "auto", "height": "auto", "minWidth": "auto", "maxWidth": "none" },
      "typography": { "fontFamily": "'Figtree', sans-serif", "fontSize": "0.875rem", "fontWeight": "400", "lineHeight": "1.5" },
      "borders": { "width": "1px", "style": "solid", "radius": "8px", "border": "1px solid #BFC6D4" },
      "states": {
        "default": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "hover": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "active": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "focus": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "disabled": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" }
      }
    }
  },
  "guidance": {
    "patterns": {},
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "click",
        "description": "Step indicator click when stepper is interactive"
      }
    ],
    "state": [
      {
        "name": "status",
        "type": "string",
        "description": "completed | current | upcoming; passed from parent Stepper"
      }
    ]
  },
  "examples": [
    {
      "name": "Step indicator",
      "description": "One step in stepper",
      "snippet": "<Step status=\"completed\" label=\"Done\" />"
    }
  ]
}