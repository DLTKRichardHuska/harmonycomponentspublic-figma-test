      "data-warning": {
        "purpose": "Indicates step has warning state",
        "location": "On step element",
        "values": ["true"],
        "optional": true,
        "usedBy": "State calculation, applies is-warning CSS class"
      },
      "data-success": {
        "purpose": "Indicates step has success state",
        "location": "On step element",
        "values": ["true"],
        "optional": true,
        "usedBy": "State calculation, applies is-success CSS class"
      },
      "data-click-handler": {
        "purpose": "Prevents re-attaching click handler in non-linear mode",
        "location": "On step element",
        "values": ["true"],
        "setBy": "initStepper after attaching click handler",
        "usedBy": "Condition check to prevent duplicate handlers"
      },
      "data-init": {
        "purpose": "Prevents double initialization",
        "values": ["true"],
        "setBy": "initStepper function after initialization",
