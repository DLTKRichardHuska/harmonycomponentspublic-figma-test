          "action": "Activates step click handler, dispatches stepper:step-clicked event"
        },
        "Tab": {
          "context": "When step has focus",
          "action": "Navigates to next focusable element",
          "note": "Only steps with tabindex='0' are focusable (active step or enabled steps in non-linear mode)"
        },
        "Shift+Tab": {
          "context": "When step has focus",
          "action": "Navigates to previous focusable element"
        }
      },
      "linearMode": {
        "description": "Steps are not clickable in linear mode - navigation must be controlled externally"
