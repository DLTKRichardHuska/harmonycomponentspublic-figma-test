      ]
    },
    "coordination": {
      "linearMode": {
        "description": "In linear mode (nonLinear=false), future steps are automatically disabled",
        "method": "Steps with index > activeStep are disabled (unless completed)",
        "actions": [
          "Add 'is-disabled' class",
          "Set data-disabled='true'",
          "Set tabindex='-1'",
          "Remove 'role' attribute"
        ],
        "note": "Completed steps remain enabled even if after active step"
      },
      "nonLinearMode": {
        "description": "In non-linear mode (nonLinear=true), all enabled steps are clickable",
        "method": "Steps are made interactive with click/keyboard handlers",
        "actions": [
          "Set tabindex='0'",
          "Set role='button'",
          "Set aria-label='Go to step {index + 1}'",
          "Attach click handler (one-time, marked with data-click-handler)",
          "Attach keydown handler (Enter/Space)"
        ],
        "note": "Disabled steps (explicitly or via data-disabled) are not made clickable"
      },
      "stepStateManagement": {
        "method": "Processes each step's data attributes and applies CSS classes",
        "classes": ["is-active", "is-completed", "is-disabled", "is-error", "is-warning", "is-success"],
        "order": "Removes all state classes first, then adds appropriate ones",
        "description": "Step visual state is managed via CSS classes based on data attributes"
      },
      "connectorLineManagement": {
        "method": "Updates .step__connector elements between steps",
        "activation": "Connector is active if: next step is completed OR next step is active OR current step is completed",
        "class": "is-active class on connector",
        "description": "Connector lines visually connect steps and show progress"
      },
      "ariaAttributes": {
        "stepper": {
          "role": "group (static)",
          "aria-label": "Stepper (static)"
        },
        "stepLabel": {
          "aria-current": "step (if active) or false (if not active)",
          "location": "On .step__label element"
        },
        "step": {
          "role": "button (in non-linear mode, if enabled)",
          "aria-label": "Go to step {index + 1} (in non-linear mode)"
        }
      },
      "stepNumbering": {
        "method": "Updates .step__number textContent with step index + 1",
        "condition": "Only if .step__icon is not present (icon takes precedence)",
        "format": "(index + 1).toString()",
        "description": "Step numbers are automatically generated if no icon is provided"
      }
    },
    "implementationNotes": [
      "Initialization checks document.readyState - if 'loading', waits for DOMContentLoaded, otherwise runs immediately",
      "Double initialization prevented by checking data-init attribute before processing",
      "Each stepper instance is processed independently via initStepper function",
      "Step states are recalculated on every initialization (reads from data attributes)",
      "In linear mode, future steps (index > activeStep) are automatically disabled unless completed",
      "In non-linear mode, future steps are enabled and made clickable (unless explicitly disabled)",
      "Click handlers are only attached once per step (data-click-handler prevents re-attachment)",
      "Custom event bubbles to allow parent components to handle step navigation",
      "Step index in custom event is 0-based (matches array index)",
      "Connector lines are updated after step state processing",
      "Step numbers are auto-generated if no icon is present (checks for .step__icon)",
      "ARIA attributes are dynamically updated based on step state",
      "Tabindex management: selected step and enabled non-linear steps have tabindex='0', others have '-1'",
      "Role attribute is removed from disabled steps in linear mode, set to 'button' in non-linear mode",
      "All state classes are removed before adding new ones to prevent conflicting states",
      "Component doesn't update activeStep itself - parent must handle step-clicked event and update",
      "Multiple state attributes can be present simultaneously (e.g., completed + success)",
      "Step visual states (error, warning, success) are independent of active/completed/disabled states"
    ]
