  "cssClassStyles": {
    ".dropdown": {
      "position": "relative",
      "display": "inline-block"
    },
    ".dropdown__trigger": {
      "display": "inline-flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "8px",
      "minWidth": "180px",
      "height": "40px",
      "padding": "0 16px 0 16px",
      "fontFamily": "'Figtree', sans-serif",
      "fontSize": "1rem",
      "color": "var(--text-primary)",
      "backgroundColor": "var(--input-bg)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "8px",
      "cursor": "pointer",
      "transition": "all 150ms ease"
    },
    ".dropdown__trigger:hover": {
      "backgroundColor": "var(--hover-bg)"
    },
    ".dropdown__trigger:focus": {
      "outline": "none",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".dropdown__value": {
      "flex": "1",
      "textAlign": "left",
      "overflow": "hidden",
      "textOverflow": "ellipsis",
      "whiteSpace": "nowrap"
    },
    ".dropdown__chevron": {
      "color": "var(--text-muted)",
      "transition": "transform 150ms ease"
    },
    ".dropdown.is-open .dropdown__chevron": {
      "transform": "rotate(180deg)"
    },
    ".dropdown__menu": {
      "display": "none",
      "position": "absolute",
      "top": "100%",
      "left": "0",
      "marginTop": "4px",
      "minWidth": "100%",
      "backgroundColor": "var(--card-bg)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "8px",
      "boxShadow": "var(--shadow-lg)",
      "padding": "4px 0",
      "zIndex": "100",
      "maxHeight": "300px",
      "overflowY": "auto"
    },
    ".dropdown.is-open .dropdown__menu": {
      "display": "block"
    },
    ".dropdown__item": {
      "display": "flex",
      "alignItems": "center",
      "gap": "8px",
      "width": "100%",
      "padding": "8px 16px",
      "fontSize": "0.875rem",
      "color": "var(--text-primary)",
      "textAlign": "left",
      "cursor": "pointer",
      "transition": "background-color 150ms ease"
    },
    ".dropdown__item:hover": {
      "backgroundColor": "var(--hover-bg)"
    },
    ".dropdown__item.is-selected": {
      "backgroundColor": "var(--theme-primary-light)",
      "color": "var(--theme-primary)"
    },
    ".dropdown__item:disabled, .dropdown__item--disabled": {
      "color": "var(--text-muted)",
      "cursor": "not-allowed"
    },
    ".dropdown-wrapper": {
      "display": "flex",
      "flexDirection": "column"
    },
    ".dropdown-wrapper--inline": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "gap": "4px"
    },
    ".dropdown-wrapper--stacked": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "6px"
    },
    ".dropdown-wrapper__label": {
      "marginBottom": "0",
      "whiteSpace": "nowrap"
    },
    ".theme-cp .dropdown-wrapper:not(.dropdown-wrapper--stacked)": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "gap": "4px"
    },
    ".theme-cp .dropdown-wrapper:not(.dropdown-wrapper--stacked) .label, .theme-cp .dropdown-wrapper:not(.dropdown-wrapper--stacked) .dropdown-wrapper__label": {
      "marginBottom": "0",
      "whiteSpace": "nowrap"
    },
    ".theme-cp .dropdown__trigger": {
      "height": "20px",
      "padding": "0 8px 0 8px",
      "fontSize": "0.75rem"
    },
    "@media (max-width: 768px)": {
      ".dropdown": {
        "width": "100%"
      },
      ".dropdown__trigger": {
        "width": "100%",
        "minWidth": "100%",
        "minHeight": "44px"
      },
      ".dropdown__menu": {
        "left": "0",
        "right": "0",
        "width": "100%",
        "maxWidth": "100vw",
        "maxHeight": "calc(100vh - 200px)"
      },
      ".dropdown__item": {
        "minHeight": "44px",
        "padding": "12px 16px"
      }
    }
  }
}
