          "light": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
          "dark": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #1F2124"
        },
        "maconomy": {
          "light": "0 0 0 3px rgba(76, 146, 217, 0.1), 0 0 0 4px #F7F8FA",
          "dark": "0 0 0 3px rgba(89, 172, 255, 0.1), 0 0 0 4px #1F2124"
        }
      }
    },
    "shadows": {
      "xl": {
        "value": "0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)",
        "valueDark": "0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 8px 10px -6px rgba(0, 0, 0, 0.3)",
        "cssVar": "--shadow-xl"
      }
    },
    "insetShadows": {
      "sm": "inset 0 1px 4px 0 rgba(0, 0, 0, 0.1)",
      "md": "inset 0 1px 4px 0 rgba(0, 0, 0, 0.2)"
    },
    "cssVars": {
      "focusRingPrimary": "--focus-ring-primary",
      "shadowXl": "--shadow-xl",
      "shadowInsetSm": "--shadow-inset-sm",
      "shadowInsetMd": "--shadow-inset-md"
    }
  },
  "states": {
    "default": {
      "cursor": "pointer",
      "textDecoration": "none"
    },
    "focus": {
      "outline": "none",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--focus-ring-primary)"
    },
    "disabled": {
      "cursor": "not-allowed",
      "pointerEvents": "auto",
      "opacity": "1"
    },
    "icon": {
      "default": {
        "cursor": "pointer",
        "opacity": "1"
      },
      "disabled": {
        "cursor": "not-allowed",
        "opacity": "0.5"
      }
    }
  },
  "cssClassStyles": {
    ".date-input-form-wrapper": {
      "display": "flex",
      "flexDirection": "column"
    },
    ".date-input-form-wrapper--inline": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "gap": "4px"
    },
    ".date-input-form-wrapper--stacked": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "6px"
    },
    ".date-input-form-wrapper__label": {
      "marginBottom": "0",
      "whiteSpace": "nowrap"
    },
    ".date-input": {
      "width": "100%",
      "height": "40px",
      "padding": "0 16px",
      "paddingRight": "40px",
      "fontFamily": "'Figtree', sans-serif",
      "fontSize": "1rem",
      "color": "var(--text-primary)",
      "backgroundColor": "var(--input-bg)",
      "border": "1px solid var(--border-color)",
      "borderRadius": "var(--radius-lg)",
      "cursor": "pointer",
      "transition": "all var(--transition-fast)"
    },
    ".date-input::-webkit-calendar-picker-indicator": {
      "display": "none",
      "webkitAppearance": "none"
    },
    ".date-input::-webkit-inner-spin-button, .date-input::-webkit-outer-spin-button": {
      "display": "none",
      "webkitAppearance": "none"
    },
    ".date-input::-moz-calendar-picker-indicator": {
      "display": "none"
    },
    ".date-input:focus": {
      "outline": "none",
      "borderColor": "var(--theme-primary)",
      "boxShadow": "var(--focus-ring-primary)"
    },
    ".date-input:disabled": {
      "backgroundColor": "var(--input-disabled-bg)",
      "color": "var(--text-muted)",
      "cursor": "not-allowed"
    },
    ".date-input::placeholder": {
      "color": "var(--text-muted)"
    },
    ".date-input-wrapper": {
      "position": "relative"
    },
    ".date-input-wrapper__icon": {
      "position": "absolute",
      "right": "16px",
      "top": "50%",
      "transform": "translateY(-50%)",
      "color": "var(--text-secondary)",
      "pointerEvents": "auto",
      "cursor": "pointer",
      "background": "transparent",
      "border": "none",
      "padding": "0",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    ".date-input-wrapper__icon:disabled": {
      "cursor": "not-allowed",
      "opacity": "0.5"
    },
    ".theme-cp .date-input-form-wrapper:not(.date-input-form-wrapper--stacked)": {
      "display": "flex",
      "flexDirection": "row",
      "alignItems": "center",
      "gap": "4px"
    },
    ".theme-cp .date-input-form-wrapper:not(.date-input-form-wrapper--stacked) .label, .theme-cp .date-input-form-wrapper:not(.date-input-form-wrapper--stacked) .date-input-form-wrapper__label": {
      "marginBottom": "0",
      "whiteSpace": "nowrap"
    },
    ".theme-cp .date-input": {
      "height": "20px",
      "padding": "0 8px",
      "paddingRight": "32px",
      "fontSize": "12px",
      "lineHeight": "20px"
    },
    ".theme-cp .date-input-wrapper__icon": {
      "right": "8px",
      "top": "calc(50% + 0.5px)"
    },
    "@media (max-width: 768px)": {
      ".date-input": {
        "width": "100%",
        "fontSize": "16px",
        "minHeight": "44px"
      }
    }
  }
}
