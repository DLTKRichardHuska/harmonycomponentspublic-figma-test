        "textDecoration": "none"
      },
      "link": {
        "textDecoration": "underline",
        "color": "var(--link-color)"
      }
    }
  },
  "cssClassStyles": {
    ".alert": {
      "display": "flex",
      "gap": "12px",
      "padding": "16px",
      "borderRadius": "8px",
      "border": "1px solid"
    },
    ".alert--info": {
      "backgroundColor": "var(--color-info-light)",
      "borderColor": "var(--color-info-border)"
    },
    ".alert--success": {
      "backgroundColor": "var(--color-success-light)",
      "borderColor": "var(--color-success-border)"
    },
    ".alert--warning": {
      "backgroundColor": "var(--color-warning-light)",
      "borderColor": "var(--color-warning-border)"
    },
    ".alert--error": {
      "backgroundColor": "var(--color-error-light)",
      "borderColor": "var(--color-error-border)"
    },
    ".alert__icon": {
      "flexShrink": "0",
      "fontSize": "20px"
    },
    ".alert--info .alert__icon": {
      "color": "var(--color-info)"
    },
    ".alert--success .alert__icon": {
      "color": "var(--color-success)"
    },
    ".alert--warning .alert__icon": {
      "color": "var(--color-warning)"
    },
    ".alert--error .alert__icon": {
      "color": "var(--color-error)"
    },
    ".alert__content": {
      "flex": "1",
      "minWidth": "0"
    },
    ".alert__title": {
      "fontFamily": "var(--font-display)",
      "fontWeight": "var(--font-semibold)",
      "color": "var(--text-primary)",
      "marginBottom": "4px"
    },
    ".alert__message": {
      "fontSize": "var(--text-sm)",
      "color": "var(--text-secondary)"
    },
    ".alert__close": {
      "flexShrink": "0",
      "color": "var(--text-muted)",
      "cursor": "pointer",
      "transition": "color 150ms ease"
    },
    ".alert__close:hover": {
      "color": "var(--text-primary)"
    },
    ".alert--enhanced": {
      "position": "relative",
      "display": "flex",
      "padding": "0",
      "border": "none",
      "borderRadius": "8px",
      "boxShadow": "var(--shadow-md)",
      "backgroundColor": "var(--card-bg)",
      "overflow": "hidden"
    },
    ".alert--enhanced .alert__border": {
      "width": "8px",
      "flexShrink": "0",
      "backgroundColor": "var(--color-info)",
      "borderRadius": "8px 0 0 8px"
    },
    ".alert--enhanced.alert--success .alert__border": {
      "backgroundColor": "var(--color-success)"
    },
    ".alert--enhanced.alert--warning .alert__border": {
      "backgroundColor": "var(--color-warning)"
    },
    ".alert--enhanced.alert--error .alert__border": {
      "backgroundColor": "var(--color-error)"
    },
    ".alert--enhanced.alert--info .alert__border": {
      "backgroundColor": "var(--color-info)"
    },
    ".alert--enhanced .alert__content": {
      "display": "flex",
      "flexDirection": "column",
      "flex": "1",
      "padding": "12px",
      "gap": "8px"
    },
    ".alert--enhanced .alert__inner": {
      "display": "flex",
      "gap": "8px",
      "alignItems": "flex-start"
    },
    ".alert--enhanced .alert__text": {
      "flex": "1",
      "minWidth": "0"
    },
    ".alert--enhanced .alert__icon": {
      "flexShrink": "0",
      "fontSize": "16px",
      "width": "20px",
      "height": "20px"
    },
    ".alert--enhanced .alert__title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-medium)",
      "color": "var(--text-primary)",
      "marginBottom": "4px",
      "lineHeight": "20px"
    },
    ".alert--enhanced .alert__message": {
      "fontSize": "13px",
      "fontWeight": "var(--font-normal)",
      "color": "var(--text-primary)",
      "lineHeight": "18px"
    },
    ".alert--enhanced .alert__close": {
      "flexShrink": "0",
      "width": "16px",
      "height": "16px",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "color": "var(--text-secondary)",
      "cursor": "pointer",
      "transition": "color 150ms ease"
    },
    ".alert--enhanced .alert__close:hover": {
      "color": "var(--text-primary)"
    },
    ".alert__actions": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "8px",
      "paddingLeft": "28px",
      "paddingTop": "8px"
    },
    ".alert__buttons": {
      "display": "flex",
      "gap": "8px",
      "alignItems": "center"
    },
    ".alert__link": {
      "fontSize": "12px",
      "fontWeight": "400",
      "color": "var(--link-color)",
      "textDecoration": "none",
      "lineHeight": "16px",
      "transition": "color 150ms ease"
    },
    ".alert__link:hover": {
      "textDecoration": "underline"
    },
    ".alert__progress": {
      "paddingTop": "8px",
      "paddingLeft": "28px"
    }
  }
