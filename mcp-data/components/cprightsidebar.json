  "states": {
    "default": {
      "root": {
        "width": "52px",
        "position": "fixed",
        "right": "0",
        "top": "50%",
        "transform": "translateY(-50%)",
        "zIndex": "200"
      },
      "section": {
        "backgroundColor": "theme-specific (see themeColors)",
        "border": "1px solid",
        "borderRight": "none",
        "borderRadius": "12px 0 0 12px",
        "boxShadow": "theme-specific (see elevations)"
      },
      "item": {
        "backgroundColor": "transparent",
        "color": "theme-specific (see themeColors)",
        "textDecoration": "none",
        "cursor": "pointer"
      },
      "label": {
        "opacity": "0",
        "visibility": "hidden"
      }
    },
    "hover": {
      "root": {
        "width": "220px"
      },
      "item": {
        "backgroundColor": "theme-specific hover color (see themeColors)",
        "textDecoration": "none"
      },
      "label": {
        "opacity": "1",
        "visibility": "visible"
      }
    },
    "focus": {
      "item": {
        "outline": "1px solid var(--card-bg)",
        "outlineOffset": "0",
        "boxShadow": "var(--focus-ring-primary)"
      }
    },
    "active": {
      "item": {
        "class": "cp-right-sidebar__item--active",
        "boxShadow": "var(--shadow-inset-sm)"
      }
    },
    "itemActive": {
      "item": {
        "class": "cp-right-sidebar__item--active",
        "description": "Applied when item.active is true"
      }
    },
    "disabled": {
      "item": {
        "opacity": "0.5",
        "cursor": "not-allowed",
        "pointerEvents": "none"
      }
    }
  },
  "cssClassStyles": {
    ".cp-right-sidebar": {
      "position": "fixed",
      "right": "0",
      "top": "50%",
      "transform": "translateY(-50%)",
      "zIndex": "200",
      "display": "flex",
      "flexDirection": "column",
      "gap": "12px",
      "width": "52px",
      "transition": "width 0.2s ease",
      "overflow": "visible"
    },
    ".cp-right-sidebar:hover": {
      "width": "220px"
    },
    ".cp-right-sidebar__section": {
      "backgroundColor": "var(--nav-bg)",
      "border": "1px solid var(--cp-sidebar-section-border)",
      "borderRight": "none",
      "borderRadius": "12px 0 0 12px",
      "boxShadow": "var(--shadow-xl)",
      "padding": "12px 8px",
      "display": "flex",
      "flexDirection": "column",
      "alignItems": "flex-end",
      "gap": "8px",
      "overflow": "visible"
    },
    ".cp-right-sidebar__item": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "flex-end",
      "gap": "8px",
      "padding": "6px",
      "borderRadius": "8px",
      "textDecoration": "none",
      "color": "var(--cp-sidebar-item-fg)",
      "whiteSpace": "nowrap",
      "width": "100%",
      "transition": "background-color 150ms ease"
    },
    ".cp-right-sidebar__item:hover": {
      "backgroundColor": "var(--cp-sidebar-item-hover-bg)",
      "textDecoration": "none"
    },
    ".cp-right-sidebar__item--active": {
      "description": "Active state class applied when item.active is true"
    },
    ".cp-right-sidebar__icon": {
      "flexShrink": "0",
      "width": "24px",
      "height": "24px",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center"
    },
    ".cp-right-sidebar__icon svg": {
      "width": "24px",
      "height": "24px"
    },
    ".cp-right-sidebar__dela-logo": {
      "width": "36px",
      "height": "36px",
      "borderRadius": "50%"
    },
    ".cp-right-sidebar__label": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-normal)",
      "opacity": "0",
      "visibility": "hidden",
      "transition": "opacity 0.2s ease, visibility 0.2s ease",
      "flex": "1",
      "textAlign": "right"
    },
    ".cp-right-sidebar:hover .cp-right-sidebar__label": {
      "opacity": "1",
      "visibility": "visible"
    },
    "html.theme-cp.dark .cp-right-sidebar__section": {
      "backgroundColor": "var(--cp-sidebar-section-bg-dark)",
      "borderColor": "var(--cp-sidebar-section-border-dark)"
    },
    "html.theme-cp.dark .cp-right-sidebar__item": {
      "color": "var(--cp-sidebar-item-fg-dark)"
    },
    "html.theme-cp.dark .cp-right-sidebar__item:hover": {
      "backgroundColor": "var(--cp-sidebar-item-hover-bg-dark)"
    }
  }
}
