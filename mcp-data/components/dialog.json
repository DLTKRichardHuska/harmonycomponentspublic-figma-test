        "transitionFast": {
          "name": "--transition-fast",
          "value": "150ms ease",
          "usage": "Overlay, dialog, and close button transitions"
        }
      },
      "colors": {
        "cardBg": {
          "name": "--card-bg",
          "value": "theme-specific",
          "reference": "themeColors.cardBg",
          "usage": "Dialog and header background color"
        },
        "elevatedBg": {
          "name": "--elevated-bg",
          "value": "theme-specific",
          "reference": "themeColors.elevatedBg",
          "usage": "Footer background color"
        },
        "textPrimary": {
          "name": "--text-primary",
          "value": "theme-specific",
          "reference": "themeColors.textPrimary",
          "usage": "Title text color, close button hover color"
        },
        "textSecondary": {
          "name": "--text-secondary",
          "value": "theme-specific",
          "reference": "themeColors.textSecondary",
          "usage": "Body text color"
        },
        "textMuted": {
          "name": "--text-muted",
          "value": "theme-specific",
          "reference": "themeColors.textMuted",
          "usage": "Close button default color"
        },
        "textInverse": {
          "name": "--text-inverse",
          "value": "theme-specific",
          "reference": "themeColors.textInverse",
          "usage": "Primary header title and close button color"
        },
        "themePrimary": {
          "name": "--theme-primary",
          "value": "theme-specific",
          "reference": "themeColors.themePrimary",
          "usage": "Primary header background and border color"
        }
      },
      "shadows": {
        "shadowXl": {
          "name": "--shadow-xl",
          "value": "0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)",
          "valueDark": "0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 8px 10px -6px rgba(0, 0, 0, 0.3)",
          "usage": "Dialog box shadow"
        }
      },
      "layout": {
        "overlayBackdropOpacity": {
          "name": "--overlay-backdrop-opacity",
          "value": "rgba(0, 0, 0, 0.5)",
          "usage": "Overlay background color"
        },
        "dialogMaxWidthDefault": {
          "name": "--dialog-max-width-default",
          "value": "500px",
          "usage": "Default dialog maximum width"
        },
        "dialogWidthPercentage": {
          "name": "--dialog-width-percentage",
