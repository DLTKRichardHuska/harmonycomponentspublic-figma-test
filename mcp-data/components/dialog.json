  },
  "states": {
    "overlay": {
      "default": {
        "opacity": "0",
        "visibility": "hidden",
        "pointerEvents": "none"
      },
      "isOpen": {
        "opacity": "1",
        "visibility": "visible",
        "pointerEvents": "auto"
      }
    },
    "dialog": {
      "default": {
        "transform": "scale(0.95)",
        "opacity": "1"
      },
      "isOpen": {
        "transform": "scale(1)",
        "opacity": "1"
      }
    },
    "closeButton": {
      "default": {
        "color": "theme-specific (see variants)",
        "cursor": "pointer"
      },
      "hover": {
        "color": "theme-specific (see variants)",
        "opacity": {
          "default": "1",
          "primary": "0.8"
        }
      },
      "focus": {
        "outline": "none"
      },
      "active": {
        "opacity": "0.7"
      }
    }
  },
  "cssClassStyles": {
    ".dialog-overlay": {
      "position": "fixed",
      "inset": "0",
      "backgroundColor": "rgba(0, 0, 0, 0.5)",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "zIndex": "300",
      "opacity": "0",
      "visibility": "hidden",
      "transition": "all 150ms ease"
    },
    ".dialog-overlay.is-open": {
      "opacity": "1",
      "visibility": "visible"
    },
    ".dialog": {
      "backgroundColor": "var(--card-bg)",
      "borderRadius": "12px",
      "boxShadow": "0 20px 25px -5px rgb(15 23 42 / 0.1), 0 8px 10px -6px rgb(15 23 42 / 0.1)",
      "maxWidth": "500px",
      "width": "90%",
      "maxHeight": "90vh",
      "overflow": "hidden",
      "transform": "scale(0.95)",
      "transition": "transform 150ms ease"
    },
    ".dialog-overlay.is-open .dialog": {
      "transform": "scale(1)"
    },
    ".dialog__header": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "padding": "16px 24px",
      "borderBottom": "1px solid var(--border-color)",
      "backgroundColor": "var(--card-bg)"
    },
    ".dialog__header--variant-primary": {
      "backgroundColor": "var(--theme-primary)",
      "borderBottomColor": "var(--theme-primary)"
    },
    ".dialog__header--variant-primary .dialog__title": {
      "color": "var(--text-inverse)"
    },
    ".dialog__header--variant-primary .dialog__close": {
      "color": "var(--text-inverse)"
    },
    ".dialog__header--variant-primary .dialog__close:hover": {
      "color": "var(--text-inverse)",
      "opacity": "0.8"
    },
    ".dialog__title": {
      "fontFamily": "'Lexend', sans-serif",
      "fontSize": "1.125rem",
      "fontWeight": "600",
      "color": "var(--text-primary)"
    },
    ".dialog__close": {
      "color": "var(--text-muted)",
      "cursor": "pointer",
      "transition": "color 150ms ease",
      "background": "none",
      "border": "none",
      "padding": "0"
    },
    ".dialog__close:hover": {
      "color": "var(--text-primary)"
    },
    ".dialog__body": {
      "padding": "24px",
      "overflowY": "auto",
      "color": "var(--text-secondary)"
    },
    ".dialog__footer": {
      "display": "flex",
      "justifyContent": "flex-start",
      "gap": "12px",
      "padding": "16px 24px",
      "borderTop": "1px solid var(--border-color)",
      "backgroundColor": "var(--elevated-bg)"
    },
    ".dialog__footer--align-right": {
      "justifyContent": "flex-end"
    },
    ".dialog__footer--align-left": {
      "justifyContent": "flex-start"
    },
    ".dialog__footer .btn": {
      "flex": "1",
      "minWidth": "120px"
    },
    "@media (max-width: 768px)": {
      ".dialog": {
        "width": "calc(100vw - 32px)",
        "maxWidth": "100%",
        "margin": "16px",
        "maxHeight": "calc(100vh - 32px)"
      },
      ".dialog__header": {
        "padding": "12px 16px"
      },
      ".dialog__body": {
        "padding": "16px",
        "maxHeight": "calc(100vh - 200px)"
      },
      ".dialog__footer": {
        "padding": "12px 16px",
        "flexWrap": "wrap",
        "gap": "8px"
      },
      ".dialog__footer .btn": {
        "flex": "1",
        "minWidth": "120px"
      }
    },
    "@media (min-width: 768px) and (max-width: 1024px)": {
      ".dialog": {
        "maxWidth": "90vw"
      }
    }
  }
}
