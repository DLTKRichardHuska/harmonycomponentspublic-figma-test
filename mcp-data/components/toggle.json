{
  "name": "Toggle",
  "type": "component",
  "filePath": "src/components/ui/Toggle.astro",
  "description": "Toggle Component",
  "props": {
    "name": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "checked": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "label": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "size": {
      "type": "'sm' | 'md'",
      "optional": true,
      "default": "'md'"
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light",
    "size": "'md'"
  },
  "specs": {
    "cp-light-md": {
      "layout": { "display": "inline-flex", "flexDirection": "row", "alignItems": "center", "justifyContent": "center", "gap": "8px" },
      "spacing": { "paddingTop": "0", "paddingRight": "0", "paddingBottom": "0", "paddingLeft": "0" },
      "dimensions": { "width": "40px", "height": "24px", "minWidth": "40px", "maxWidth": "none" },
      "typography": { "fontFamily": "'Figtree', sans-serif", "fontSize": "0.875rem", "fontWeight": "400", "lineHeight": "1.5" },
      "borders": { "width": "1px", "style": "solid", "radius": "9999px", "border": "1px solid #BFC6D4" },
      "states": {
        "default": { "background": "#E5E7EB", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "hover": { "background": "#E5E7EB", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "active": { "background": "#4C92D9", "text": "#FFFFFF", "border": "none", "iconColor": "#FFFFFF" },
        "focus": { "background": "#E5E7EB", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" },
        "disabled": { "background": "#F7F8FA", "text": "#373F4E", "border": "1px solid #BFC6D4", "iconColor": "#373F4E" }
      }
    }
  },
  "guidance": {
    "patterns": {},
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "change",
        "description": "Native change when the switch is toggled; use for form binding or controlled state"
      }
    ],
    "state": [
      {
        "name": "checked",
        "type": "boolean",
        "description": "Controlled via the checked prop or form value"
      }
    ]
  },
  "examples": [
    {
      "name": "Switch",
      "description": "On/off toggle",
      "snippet": "<Toggle label=\"Enable\" name=\"enabled\" />"
    }
  ]
}