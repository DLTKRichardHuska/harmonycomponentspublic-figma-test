  "cssClassStyles": {
    ".kanban__container": {
      "display": "flex",
      "flexDirection": "column",
      "width": "100%",
      "height": "100%"
    },
    ".kanban__title-bar": {
      "padding": "16px 16px 12px",
      "borderBottom": "1px solid",
      "borderBottomColor": "var(--border-light)",
      "backgroundColor": "var(--card-bg)"
    },
    ".kanban__title-bar-content": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between"
    },
    ".kanban__title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--heading-l)",
      "fontWeight": "var(--font-semibold)",
      "lineHeight": "var(--leading-snug)",
      "color": "var(--text-primary)",
      "margin": "0"
    },
    ".kanban__title-bar-actions": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".kanban__title-bar-icon": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "width": "var(--space-6)",
      "height": "var(--space-6)",
      "padding": "0",
      "border": "none",
      "background": "transparent",
      "color": "var(--text-secondary)",
      "cursor": "pointer",
      "borderRadius": "var(--radius-04)",
      "transition": "background-color var(--transition-fast), color var(--transition-fast)"
    },
    ".kanban__title-bar-icon:hover": {
      "backgroundColor": "var(--elevated-bg)",
      "color": "var(--text-primary)"
    },
    ".kanban__title-bar-icon:focus": {
      "outline": "2px solid var(--theme-primary)",
      "outlineOffset": "2px"
    },
    ".kanban__action-bar": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "padding": "12px 16px",
      "borderBottom": "1px solid",
      "borderBottomColor": "var(--border-light)",
      "backgroundColor": "var(--table-header-gray-bg)",
      "gap": "var(--space-4)"
    },
    ".kanban__action-items": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)",
      "flexWrap": "wrap"
    },
    ".kanban__action-button": {
      "flexShrink": "0"
    },
    ".kanban__action-divider": {
      "color": "var(--text-secondary)",
      "fontSize": "var(--text-sm)",
      "padding": "0 var(--space-1)",
      "flexShrink": "0"
    },
    ".kanban__action-label": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-normal)",
      "color": "var(--text-primary)",
      "padding": "var(--space-1) var(--space-2)",
      "flexShrink": "0"
    },
    ".kanban__action-text-button": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-1)",
      "padding": "var(--space-1) var(--space-2)",
      "border": "none",
      "background": "transparent",
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-normal)",
      "color": "var(--text-primary)",
      "cursor": "pointer",
      "borderRadius": "var(--radius-04)",
      "transition": "background-color var(--transition-fast)",
      "flexShrink": "0"
    },
    ".kanban__action-text-button:hover": {
      "backgroundColor": "var(--elevated-bg)"
    },
    ".kanban__action-text-button:focus": {
      "outline": "2px solid var(--theme-primary)",
      "outlineOffset": "2px"
    },
    ".kanban__columns-wrapper": {
      "display": "flex",
      "gap": "var(--space-4)",
      "overflowX": "auto",
      "padding": "var(--space-4)",
      "minHeight": "400px",
      "flex": "1"
    },
    ".kanban__column-card": {
      "flex": "0 0 400px",
      "minWidth": "360px",
      "maxWidth": "500px",
      "display": "flex",
      "flexDirection": "column",
      "overflow": "hidden"
    },
    ".kanban__column-card--in-progress.card--primary": {
      "borderTopColor": "var(--kanban-in-progress-border)"
    },
    ".kanban__column-card--done.card--primary": {
      "borderTopColor": "var(--kanban-done-border)"
    },
    ".kanban__column-card .card__body": {
      "padding": "0",
      "display": "flex",
      "flexDirection": "column",
      "height": "100%"
    },
    ".kanban__column": {
      "display": "flex",
      "flexDirection": "column",
      "height": "100%",
      "flex": "1"
    },
    ".kanban__column-header": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "padding": "16px 16px 12px",
      "borderBottom": "1px solid",
      "borderBottomColor": "var(--border-light)",
      "backgroundColor": "var(--card-bg)"
    },
    ".kanban__column-header-content": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".kanban__column-title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--heading-s)",
      "fontWeight": "var(--font-semibold)",
      "lineHeight": "var(--leading-tight)",
      "color": "var(--text-primary)",
      "margin": "0"
    },
    ".kanban__column-count": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--caption)",
      "fontWeight": "var(--font-medium)",
      "lineHeight": "var(--leading-normal)",
      "color": "var(--text-secondary)",
      "backgroundColor": "var(--elevated-bg)",
      "padding": "2px 8px",
      "borderRadius": "var(--radius-full)",
      "minWidth": "24px",
      "textAlign": "center"
    },
    ".kanban__column-header-actions": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".kanban__column-action-icon": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "width": "var(--space-6)",
      "height": "var(--space-6)",
      "padding": "0",
      "border": "none",
      "background": "transparent",
      "color": "var(--text-secondary)",
      "cursor": "pointer",
      "borderRadius": "var(--radius-04)",
      "transition": "background-color var(--transition-fast), color var(--transition-fast)"
    },
    ".kanban__column-action-icon:hover": {
      "backgroundColor": "var(--elevated-bg)",
      "color": "var(--text-primary)"
    },
    ".kanban__column-action-icon:focus": {
      "outline": "2px solid var(--theme-primary)",
      "outlineOffset": "2px"
    },
    ".kanban__add-button": {
      "flexShrink": "0",
      "marginTop": "var(--space-2)"
    },
    ".kanban__add-column-button": {
      "flexShrink": "0",
      "alignSelf": "flex-start",
      "marginTop": "var(--space-4)"
    },
    ".kanban__column-content": {
      "flex": "1",
      "overflowY": "auto",
      "overflowX": "hidden",
      "padding": "var(--space-3)",
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--space-3)",
      "minHeight": "200px"
    },
    ".kanban__column-content::-webkit-scrollbar": {
      "width": "var(--space-2)"
    },
    ".kanban__column-content::-webkit-scrollbar-track": {
      "background": "transparent"
    },
    ".kanban__column-content::-webkit-scrollbar-thumb": {
      "backgroundColor": "var(--border-color)",
      "borderRadius": "var(--radius-04)"
    },
    ".kanban__column-content::-webkit-scrollbar-thumb:hover": {
      "backgroundColor": "var(--text-secondary)"
    },
    ".kanban-card": {
      "cursor": "pointer",
      "transition": "transform var(--transition-fast), box-shadow var(--transition-fast)"
    },
    ".kanban-card:hover": {
      "transform": "translateY(-2px)",
      "boxShadow": "var(--shadow-md)"
    },
    ".kanban-card .card__body": {
      "padding": "var(--space-4)",
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--space-3)"
    },
    ".kanban-card__header": {
      "display": "flex",
      "alignItems": "flex-start",
      "justifyContent": "space-between",
      "gap": "var(--space-3)",
      "marginBottom": "var(--space-2)",
      "minHeight": "32px"
    },
    ".kanban-card__avatar": {
      "flexShrink": "0"
    },
    ".kanban-card__header-right": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)",
      "flexWrap": "wrap",
      "flexShrink": "0"
    },
    ".kanban-card__icons": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".kanban-card__icon": {
      "color": "var(--text-secondary)",
      "flexShrink": "0"
    },
    ".kanban-card__badges": {
      "display": "flex",
      "flexWrap": "wrap",
      "gap": "var(--space-1)"
    },
    ".kanban-card__description": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-normal)",
      "lineHeight": "var(--leading-normal)",
      "color": "var(--text-secondary)",
      "margin": "0"
    },
    ".kanban-card__progress": {
      "width": "100%"
    },
    ".kanban-card__title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--body-default)",
      "fontWeight": "var(--font-semibold)",
      "lineHeight": "var(--leading-snug)",
      "color": "var(--text-primary)",
      "margin": "0 0 var(--space-2) 0"
    },
    ".kanban-card__date-time": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "var(--space-4)",
      "marginTop": "var(--space-2)",
      "paddingTop": "var(--space-2)",
      "borderTop": "1px solid",
      "borderTopColor": "var(--border-light)",
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-medium)",
      "lineHeight": "var(--leading-normal)",
      "color": "var(--text-secondary)",
      "minHeight": "var(--space-5)",
      "flexWrap": "wrap"
    },
    ".kanban-card__date, .kanban-card__time": {
      "flexShrink": "0",
      "whiteSpace": "nowrap"
    },
    "@media (max-width: var(--breakpoint-md))": {
      ".kanban__container": {
        "padding": "0"
      },
      ".kanban__title-bar": {
        "padding": "var(--space-3)"
      },
      ".kanban__action-bar": {
        "flexDirection": "column",
        "alignItems": "stretch",
        "padding": "var(--space-3)",
        "gap": "var(--space-3)"
      },
      ".kanban__columns-wrapper": {
        "flexDirection": "column",
        "gap": "var(--space-4)",
        "padding": "var(--space-3)"
      },
      ".kanban__column-card": {
        "flex": "1 1 auto",
        "minWidth": "100%",
        "maxWidth": "100%"
      },
      ".kanban__column-header": {
        "padding": "var(--space-3)"
      },
      ".kanban__column-content": {
        "padding": "var(--space-2)",
        "gap": "var(--space-2)"
      },
      ".kanban-card .card__body": {
        "padding": "var(--space-3)"
      }
    }
  }
}
