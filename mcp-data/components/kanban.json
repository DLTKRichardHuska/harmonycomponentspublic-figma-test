        "height": "100%"
      },
      "titleBarIcon": {
        "backgroundColor": "transparent",
        "color": "text-secondary (theme-specific)",
        "cursor": "pointer"
      },
      "actionTextButton": {
        "backgroundColor": "transparent",
        "color": "text-primary (theme-specific)",
        "cursor": "pointer"
      },
      "columnActionIcon": {
        "backgroundColor": "transparent",
        "color": "text-secondary (theme-specific)",
        "cursor": "pointer"
      },
      "kanbanCard": {
        "cursor": "pointer",
