      "border": "1px solid transparent",
      "border-radius": "0.375rem",
      "cursor": "pointer",
      "transition": "all 150ms ease"
    },
    ".week-picker__week:hover:not(:disabled)": {
      "background-color": "#E5E7EB",
      "border-color": "#BFC6D4"
    },
    ".week-picker__week--selected": {
      "background-color": "#4C92D9",
      "color": "#FFFFFF",
      "border-color": "#4C92D9",
      "font-weight": "600"
    },
