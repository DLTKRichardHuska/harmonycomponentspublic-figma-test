{
  "name": "KanbanCard",
  "type": "component",
  "filePath": "src/components/ui/KanbanCard.astro",
  "description": "KanbanCard Component",
  "props": {
    "id": {
      "type": "string",
      "optional": false,
      "default": null
    },
    "title": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "description": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "avatar": {
      "type": "{ name?: string; size?: 'sm' | 'md' | 'lg' }",
      "optional": true,
      "default": null
    },
    "badges": {
      "type": "Array<{ label: string; variant?: BadgeVariant }>",
      "optional": true,
      "default": "[]"
    },
    "progress": {
      "type": "number",
      "optional": true,
      "default": null
    },
    "icons": {
      "type": "Array<{ name: string; size?: 'xs' | 'sm' | 'md' }>",
      "optional": true,
      "default": "[]"
    },
    "date": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "time": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
