  "elevations": {
    "shadows": {
      "sm": {
        "light": "0 1px 2px 0 rgb(15 23 42 / 0.05)",
        "dark": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
        "cssVar": "--shadow-sm"
      },
      "md": {
        "light": "0 4px 6px -1px rgb(15 23 42 / 0.1), 0 2px 4px -2px rgb(15 23 42 / 0.1)",
        "dark": "0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -2px rgba(0, 0, 0, 0.2)",
        "cssVar": "--shadow-md"
      },
      "lg": {
        "light": "0 10px 15px -3px rgb(15 23 42 / 0.1), 0 4px 6px -4px rgb(15 23 42 / 0.1)",
        "dark": "0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.3)",
        "cssVar": "--shadow-lg"
      }
    },
    "cssVars": {
      "shadowSm": "--shadow-sm",
      "shadowMd": "--shadow-md",
      "shadowLg": "--shadow-lg"
    }
  },
  "states": {
    "default": {
      "root": {
        "cursor": "pointer",
        "transition": "transform 150ms ease, box-shadow 150ms ease"
      },
      "header": {
        "display": "flex",
        "alignItems": "flex-start",
        "justifyContent": "space-between",
        "gap": "12px",
        "marginBottom": "8px",
        "minHeight": "32px"
      },
      "icon": {
        "color": "theme-specific (--text-secondary)",
        "flexShrink": "0"
      },
      "title": {
        "fontFamily": "'Lexend', sans-serif",
        "fontSize": "1rem",
        "fontWeight": "600",
        "lineHeight": "1.375",
        "color": "theme-specific (--text-primary)",
        "margin": "0 0 8px 0"
      },
      "description": {
        "fontFamily": "'Figtree', sans-serif",
        "fontSize": "0.875rem",
        "fontWeight": "400",
        "lineHeight": "1.5",
        "color": "theme-specific (--text-secondary)",
        "margin": "0"
      },
      "dateTime": {
        "display": "flex",
        "alignItems": "center",
        "justifyContent": "space-between",
        "gap": "16px",
        "marginTop": "8px",
        "paddingTop": "8px",
        "borderTop": "1px solid theme-specific (--border-light)",
        "fontFamily": "'Figtree', sans-serif",
        "fontSize": "0.875rem",
        "fontWeight": "500",
        "lineHeight": "1.5",
        "color": "theme-specific (--text-secondary)",
        "minHeight": "20px",
        "flexWrap": "wrap"
      }
    },
    "hover": {
      "root": {
        "transform": "translateY(-2px)",
        "boxShadow": "theme-specific (--shadow-md)"
      }
    },
    "focus": {
      "root": {
        "outline": "none"
      }
    },
    "disabled": {
      "root": {
        "opacity": "0.5",
        "cursor": "not-allowed",
        "pointerEvents": "none"
      }
    }
  },
  "cssClassStyles": {
    ".kanban-card": {
      "cursor": "pointer",
      "transition": "transform var(--transition-fast), box-shadow var(--transition-fast)"
    },
    ".kanban-card:hover": {
      "transform": "translateY(-2px)",
      "boxShadow": "var(--shadow-md)"
    },
    ".kanban-card .card__body": {
      "padding": "var(--space-4)",
      "display": "flex",
      "flexDirection": "column",
      "gap": "var(--space-3)"
    },
    ".kanban-card__header": {
      "display": "flex",
      "alignItems": "flex-start",
      "justifyContent": "space-between",
      "gap": "var(--space-3)",
      "marginBottom": "var(--space-2)",
      "minHeight": "32px"
    },
    ".kanban-card__avatar": {
      "flexShrink": "0"
    },
    ".kanban-card__header-right": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)",
      "flexWrap": "wrap",
      "flexShrink": "0"
    },
    ".kanban-card__icons": {
      "display": "flex",
      "alignItems": "center",
      "gap": "var(--space-2)"
    },
    ".kanban-card__icon": {
      "color": "var(--text-secondary)",
      "flexShrink": "0"
    },
    ".kanban-card__badges": {
      "display": "flex",
      "flexWrap": "wrap",
      "gap": "var(--space-1)"
    },
    ".kanban-card__title": {
      "fontFamily": "var(--font-display)",
      "fontSize": "var(--body-default)",
      "fontWeight": "var(--font-semibold)",
      "lineHeight": "var(--leading-snug)",
      "color": "var(--text-primary)",
      "margin": "0 0 var(--space-2) 0"
    },
    ".kanban-card__description": {
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-normal)",
      "lineHeight": "var(--leading-normal)",
      "color": "var(--text-secondary)",
      "margin": "0"
    },
    ".kanban-card__progress": {
      "width": "100%"
    },
    ".kanban-card__date-time": {
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "space-between",
      "gap": "var(--space-4)",
      "marginTop": "var(--space-2)",
      "paddingTop": "var(--space-2)",
      "borderTop": "1px solid var(--border-light)",
      "fontFamily": "var(--font-sans)",
      "fontSize": "var(--text-sm)",
      "fontWeight": "var(--font-medium)",
      "lineHeight": "var(--leading-normal)",
      "color": "var(--text-secondary)",
      "minHeight": "var(--space-5)",
      "flexWrap": "wrap"
    },
    ".kanban-card__date,\n.kanban-card__time": {
      "flexShrink": "0",
      "whiteSpace": "nowrap"
    },
    "@media (max-width: var(--breakpoint-md))": {
      ".kanban-card .card__body": {
        "padding": "var(--space-3)"
      }
    }
  }
}
