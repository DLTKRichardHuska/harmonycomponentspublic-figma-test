{
  "name": "ShellHeader",
  "type": "component",
  "filePath": "src/components/ui/ShellHeader.astro",
  "description": "ShellHeader: top bar with brand and optional company picker + avatar.",
  "props": {
    "productName": {
      "type": "string",
      "optional": true,
      "default": "'Harmony'"
    },
    "logoSrc": {
      "type": "string",
      "optional": true,
      "default": "'/logos/CPVPLogo.svg'"
    },
    "companyName": {
      "type": "string",
      "optional": true,
      "default": "'Company name'"
    },
    "showCompanyPicker": {
      "type": "boolean",
      "optional": true,
      "default": "true"
    },
    "companyColor": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "companies": {
      "type": "CompanyOption[]",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".header": {
            "width": "100%",
            "height": "56px",
            "background-color": "#FCFDFF",
            "border-bottom": "none",
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "padding": "0 16px",
            "position": "relative",
            "z-index": "50",
            "flex-shrink": "0"
          },
          ".header__actions": {
            "display": "flex",
            "align-items": "center",
            "gap": "12px"
          },
          ".header__brand": {
            "display": "flex",
            "align-items": "center",
            "gap": "16px"
          },
          ".header__brand-link": {
            "display": "flex",
            "align-items": "center",
            "gap": "8px",
            "text-decoration": "none"
          },
          ".header__center": {
            "display": "none",
            "position": "absolute",
            "left": "50%",
            "top": "50%",
            "transform": "translate(-50%, -50%)"
          },
          ".header__gradient": {
            "position": "absolute",
            "bottom": "0",
            "left": "0",
            "width": "100%",
            "height": "6px",
            "pointer-events": "none"
          },
          ".header__logo": {
            "width": "20px",
            "height": "20px",
            "border-radius": "9999px"
          },
          ".header__title": {
            "font-family": "'Lexend', sans-serif",
            "font-weight": "700",
            "font-size": "0.875rem",
            "color": "#373F4E",
            "letter-spacing": "-0.025em"
          },
          ".header__title-product": {
            "color": "#4C92D9"
          },
          ".header__title-suffix": {
            "color": "#6B7280",
            "font-weight": "400"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values"
        ]
      },
