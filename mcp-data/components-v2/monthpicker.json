{
  "name": "MonthPicker",
  "type": "component",
  "filePath": "src/components/ui/MonthPicker.astro",
  "description": "MonthPicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "locale": {
      "type": "string",
      "optional": true,
      "default": "'en-US'"
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".month-picker": {
            "width": "100%"
          },
          ".month-picker__grid": {
            "display": "grid",
            "grid-template-columns": "repeat(3, 1fr)",
            "gap": "8px"
          },
          ".month-picker__header": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "margin-bottom": "16px"
          },
          ".month-picker__month": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "height": "40px",
            "padding": "0 12px",
            "font-size": "0.875rem",
            "font-family": "'Figtree', sans-serif",
            "color": "#373F4E",
            "background": "transparent",
            "border": "1px solid #BFC6D4",
            "border-radius": "0.375rem",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".month-picker__nav-btn": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "width": "32px",
            "height": "32px",
            "padding": "0",
            "background": "transparent",
            "border": "1px solid #BFC6D4",
            "border-radius": "0.375rem",
            "color": "#525969",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".month-picker__year": {
            "font-family": "'Lexend', sans-serif",
            "font-size": "1rem",
            "font-weight": "600",
            "color": "#373F4E"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values"
        ]
      },
      "elements": [
        {
          "selector": ".month-picker",
          "tag": "div",
          "styles": {
            "width": "100%"
          },
          "children": [
            ".month-picker__grid",
            ".month-picker__header",
            ".month-picker__month",
            ".month-picker__nav-btn",
            ".month-picker__year"
          ]
        },
        {
          "selector": ".month-picker__grid",
          "tag": "span",
          "styles": {
