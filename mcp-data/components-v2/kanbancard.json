      "type": "{ name?: string; size?: 'sm' | 'md' | 'lg' }",
      "optional": true,
      "default": null
    },
    "badges": {
      "type": "Array<{ label: string; variant?: BadgeVariant }>",
      "optional": true,
      "default": "[]"
    },
    "progress": {
      "type": "number",
      "optional": true,
      "default": null
    },
    "icons": {
      "type": "Array<{ name: string; size?: 'xs' | 'sm' | 'md' }>",
      "optional": true,
      "default": "[]"
    },
    "date": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "time": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".kanban-card": {
            "cursor": "pointer",
            "transition": "transform 150ms ease, box-shadow 150ms ease"
          },
          ".kanban-card__avatar": {
            "flex-shrink": "0"
          },
          ".kanban-card__badges": {
            "display": "flex",
            "flex-wrap": "wrap",
            "gap": "4px"
          },
          ".kanban-card__date": {
            "flex-shrink": "0",
            "white-space": "nowrap"
          },
          ".kanban-card__date-time": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "gap": "16px",
            "margin-top": "8px",
            "padding-top": "8px",
            "border-top": "1px solid #BFC6D4",
            "font-family": "'Figtree', sans-serif",
            "font-size": "0.875rem",
            "font-weight": "500",
            "line-height": "1.5",
            "color": "#525969",
            "min-height": "20px",
            "flex-wrap": "wrap"
          },
          ".kanban-card__description": {
            "font-family": "'Figtree', sans-serif",
            "font-size": "0.875rem",
            "font-weight": "400",
            "line-height": "1.5",
            "color": "#525969",
            "margin": "0"
          },
          ".kanban-card__header": {
            "display": "flex",
            "align-items": "flex-start",
            "justify-content": "space-between",
            "gap": "12px",
            "margin-bottom": "8px",
            "min-height": "32px"
          },
          ".kanban-card__header-right": {
            "display": "flex",
            "align-items": "center",
            "gap": "8px",
            "flex-wrap": "wrap",
            "flex-shrink": "0"
          },
          ".kanban-card__icon": {
            "color": "#525969",
            "flex-shrink": "0"
          },
          ".kanban-card__icons": {
            "display": "flex",
            "align-items": "center",
            "gap": "8px"
          },
          ".kanban-card__progress": {
            "width": "100%"
          },
          ".kanban-card__time": {
            "flex-shrink": "0",
            "white-space": "nowrap"
          },
          ".kanban-card__title": {
            "font-family": "'Lexend', sans-serif",
            "font-size": "1rem",
            "font-weight": "600",
            "line-height": "1.375",
            "color": "#373F4E",
            "margin": "0 0 8px 0"
          }
        },
