            "border": "1px solid #BFC6D4",
            "border-radius": "0.375rem",
            "color": "#525969",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".week-picker__week": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "width": "100%",
            "padding": "8px 12px",
