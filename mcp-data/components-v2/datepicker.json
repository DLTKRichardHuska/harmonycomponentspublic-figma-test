{
  "name": "DatePicker",
  "type": "component",
  "filePath": "src/components/ui/DatePicker.astro",
  "description": "DatePicker Component",
  "props": {
    "value": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "min": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "max": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "disabled": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "locale": {
      "type": "string",
      "optional": true,
      "default": "'en-US'"
    },
    "id": {
      "type": "string",
      "optional": true,
      "default": null
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".date-picker": {
            "width": "100%"
          },
          ".date-picker__day": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "width": "36px",
            "height": "36px",
            "padding": "0",
            "font-size": "0.875rem",
            "font-family": "'Figtree', sans-serif",
            "color": "#373F4E",
            "background": "transparent",
            "border": "1px solid transparent",
            "border-radius": "0.375rem",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".date-picker__grid": {
            "display": "grid",
            "grid-template-columns": "repeat(7, 1fr)",
            "gap": "4px"
          },
          ".date-picker__header": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "margin-bottom": "16px"
          },
          ".date-picker__month-year": {
            "display": "flex",
            "align-items": "center",
            "gap": "8px",
            "font-family": "'Lexend', sans-serif",
            "font-size": "1rem",
            "font-weight": "600",
            "color": "#373F4E"
          },
          ".date-picker__nav-btn": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "width": "32px",
            "height": "32px",
            "padding": "0",
            "background": "transparent",
            "border": "1px solid #BFC6D4",
            "border-radius": "0.375rem",
            "color": "#525969",
            "cursor": "pointer",
            "transition": "all 150ms ease"
          },
          ".date-picker__weekday": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "center",
            "height": "32px",
            "font-size": "0.75rem",
            "font-weight": "500",
            "color": "#6B7280",
            "text-align": "center"
          },
          ".date-picker__weekdays": {
            "display": "grid",
            "grid-template-columns": "repeat(7, 1fr)",
            "gap": "4px",
            "margin-bottom": "8px"
          }
        },
