{
  "name": "Accordion",
  "type": "component",
  "filePath": "src/components/ui/Accordion.astro",
  "description": "Accordion Component",
  "props": {
    "items": {
      "type": "AccordionItem[]",
      "optional": false,
      "default": null
    },
    "allowMultiple": {
      "type": "boolean",
      "optional": true,
      "default": "false"
    },
    "class": {
      "type": "string",
      "optional": true,
      "default": "''"
    }
  },
  "defaults": {
    "theme": "cp",
    "mode": "light"
  },
  "specs": {
    "cp-light": {
      "_meta": {
        "theme": "cp",
        "mode": "light",
        "locked": true
      },
      "_buildContract": {
        "criticalSelectors": {
          ".accordion": {
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "overflow": "hidden"
          },
          ".accordion__content": {
            "display": "none",
            "padding": "0 16px 16px",
            "font-size": "0.875rem",
            "color": "#525969"
          },
          ".accordion__icon": {
            "color": "#6B7280",
            "transition": "transform 150ms ease"
          },
          ".accordion__item": {
            "border-bottom": "1px solid #BFC6D4"
          },
          ".accordion__trigger": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "width": "100%",
            "padding": "16px",
            "font-size": "1rem",
            "font-weight": "500",
            "color": "#373F4E",
            "text-align": "left",
            "background-color": "transparent",
            "cursor": "pointer",
            "transition": "background-color 150ms ease"
          }
        },
        "forbiddenModifications": [
          "Do not use Tailwind arbitrary values",
          "Do not change hex colors to named colors",
          "Do not simplify box-shadow values"
        ]
      },
      "elements": [
        {
          "selector": ".accordion",
          "tag": "div",
          "styles": {
            "border": "1px solid #BFC6D4",
            "border-radius": "0.5rem",
            "overflow": "hidden"
          },
          "children": [
            ".accordion__content",
            ".accordion__icon",
            ".accordion__item",
            ".accordion__trigger"
          ]
        },
        {
          "selector": ".accordion__content",
          "tag": "span",
          "styles": {
            "display": "none",
            "padding": "0 16px 16px",
            "font-size": "0.875rem",
            "color": "#525969"
          },
          "parent": ".accordion"
        },
        {
          "selector": ".accordion__icon",
          "tag": "span",
          "styles": {
            "color": "#6B7280",
            "transition": "transform 150ms ease"
          },
          "parent": ".accordion"
        },
        {
          "selector": ".accordion__item",
          "tag": "span",
          "styles": {
            "border-bottom": "1px solid #BFC6D4"
          },
          "parent": ".accordion"
        },
        {
          "selector": ".accordion__trigger",
          "tag": "span",
          "styles": {
            "display": "flex",
            "align-items": "center",
            "justify-content": "space-between",
            "width": "100%",
            "padding": "16px",
            "font-size": "1rem",
            "font-weight": "500",
            "color": "#373F4E",
            "text-align": "left",
            "background-color": "transparent",
            "cursor": "pointer",
            "transition": "background-color 150ms ease"
          },
          "parent": ".accordion"
        }
      ]
    }
  },
  "guidance": {
    "patterns": {
      "named-slots-content": "Use named slots item-0 through item-9 (max 10 items) to provide custom HTML content for accordion bodies. When a named slot exists for an item index, it takes precedence and the item.content string is ignored. If no named slot exists, the item.content string is rendered as plain text. Do not provide both slot and content for the same item.",
      "allow-multiple-behavior": "When allowMultiple prop is false (default), clicking an accordion item automatically closes all other open items, allowing only one section open at a time. When allowMultiple is true, multiple sections can remain open simultaneously. This affects the click handler behavior in lines 76-81.",
      "default-open-state": "Set defaultOpen: true on individual items in the items array to have them open when the accordion first renders. In single-open mode (allowMultiple=false), only the last item with defaultOpen: true will remain open. In multi-open mode, all items marked defaultOpen will be open initially."
    },
    "guidelines": {}
  },
  "interactivity": {
    "events": [
      {
        "name": "toggle",
        "description": "Triggered when an accordion item header is clicked; toggles that section open/closed"
      }
    ],
    "state": [
      {
        "name": "openItems",
        "type": "string[]",
        "description": "Which items are expanded; controlled via .is-open on accordion__item. With allowMultiple=false only one can be open."
      }
    ]
  },
  "examples": [
    {
      "name": "Basic accordion",
      "description": "Single open section at a time",
      "snippet": "<Accordion items={[{ title: 'Section 1', content: '...' }, { title: 'Section 2', content: '...' }]} />"
    },
    {
      "name": "Multiple open",
      "description": "Allow multiple sections open",
      "snippet": "<Accordion items={...} allowMultiple />"
    }
  ]
}
